{
  "name": "opencode-planhtml",
  "version": "0.1.1",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "description": "GitHub-installable OpenCode overlay that patches PLAN with HTML rendering and browser opening.",
  "bin": {
    "opencode-planhtml": "./bin/opencode-planhtml.mjs"
  },
  "scripts": {
    "export:opencode-planhtml-patch": "node ./scripts/export-opencode-planhtml-patch.mjs",
    "smoke:installer": "node ./scripts/smoke-opencode-planhtml-installer.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
