+function getSelectableNodeElement(target: Node | null) {
+  const element = target instanceof Element ? target : target?.parentElement
+  return element?.closest<HTMLElement>("[data-plan-node-text][data-plan-node-id]") ?? null
+}
+
+function resolveTextRange(text: string, anchor: TextRangeAnchor) {
+  if (anchor.start !== undefined && anchor.end !== undefined && text.slice(anchor.start, anchor.end) === anchor.quote) {
+    return { start: anchor.start, end: anchor.end }
+  }
+
+  const matches: number[] = []
+  let cursor = text.indexOf(anchor.quote)
+  while (cursor >= 0) {
+    matches.push(cursor)
+    cursor = text.indexOf(anchor.quote, cursor + Math.max(1, anchor.quote.length))
+  }
+
+  for (const start of matches) {
+    const end = start + anchor.quote.length
+    const prefix = anchor.prefix ? text.slice(Math.max(0, start - anchor.prefix.length), start) : undefined
+    const suffix = anchor.suffix ? text.slice(end, Math.min(text.length, end + anchor.suffix.length)) : undefined
+    if ((anchor.prefix ? prefix === anchor.prefix : true) && (anchor.suffix ? suffix === anchor.suffix : true)) {
+      return { start, end }
+    }
+  }
+
+  if (!matches.length) return null
+  return { start: matches[0], end: matches[0] + anchor.quote.length }
+}

