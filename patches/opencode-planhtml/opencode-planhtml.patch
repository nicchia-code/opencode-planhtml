+    "@media (prefers-color-scheme: dark) { :root { --bg: #111111; --panel: #171717; --panel-muted: #1f1f1f; --text: #f5f5f5; --muted: #a3a3a3; --border: #333333; --accent: #5eead4; --accent-strong: #99f6e4; --danger: #f87171; --code: #202020; --shadow: none; } }",
+    "* { box-sizing: border-box; }",
+    "html { scroll-behavior: smooth; }",
+    "body { margin: 0; font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); }",
+    "main { max-width: 1040px; margin: 0 auto; padding: 32px 16px 120px; }",
