+import { describe, expect, test } from "bun:test"
+import fs from "node:fs/promises"
+import path from "node:path"
+
+import { Session } from "../../src/session"
+import * as SessionPlanHtml from "../../src/session/plan-html"
+import { MessageV2 } from "../../src/session/message-v2"
+import { MessageID, PartID, SessionID } from "../../src/session/schema"
+import { Instance } from "../../src/project/instance"
+import { tmpdir } from "../fixture/fixture"
+
+const SAMPLE_PLAN = `# Goal
+Add an HTML plan artifact that is easy to review in a browser.
+
+# Plan Rationale
+We want a durable **plan artifact** with rationale, sections, and a [final summary table](https://example.com/summary).
+
+# Actions
+## Step 1: Analyze the current plan output
+What: Inspect the existing plan prompts and completion flow.
+Why: We need a reliable integration point before generating artifacts.
+Files/Tests: packages/opencode/src/session/prompt.ts, packages/opencode/src/session/processor.ts
+
+- Review the prompt contract
+- Confirm how completed plan messages are persisted
+
+## Step 2: Generate the HTML artifact
+What: Render a dedicated HTML file from the final plan content.
+Why: This gives the user a clean browser view with anchors and recap links.
+Files/Tests: packages/opencode/src/session/plan-html.ts, packages/opencode/src/tool/plan.ts
+
+- Write the renderer
+- Attach the generated HTML file to the message
+`
+
+describe("session.plan-html", () => {
+  test("builds a plan document with revision metadata and commentable steps", () => {
+    const document = SessionPlanHtml.buildPlanDocument(SAMPLE_PLAN, ".opencode/plans/example.md")
+
+    expect(document.planRevisionID).toHaveLength(64)
+    expect(document.summaryRows).toHaveLength(2)
+    expect(document.sections.some((section) => section.commentable)).toBe(true)
+    expect(document.sections.find((section) => section.id === "step-1-analyze-the-current-plan-output")?.action).toBe(
+      "Inspect the existing plan prompts and completion flow.",
+    )
+    expect(document.sections.find((section) => section.id === "step-2-generate-the-html-artifact")?.filesTests).toBe(
+      "packages/opencode/src/session/plan-html.ts, packages/opencode/src/tool/plan.ts",
+    )
+  })
+
+  test("renders sections and a final summary table", () => {
+    const html = SessionPlanHtml.renderPlanHtml(SAMPLE_PLAN, ".opencode/plans/example.md")
+
+    expect(html).toContain("Plan Summary")
+    expect(html).toContain("Jump")
+    expect(html.indexOf("Plan Summary")).toBeLessThan(html.indexOf("Step 1: Analyze the current plan output"))
+    expect(html).toContain('id="step-1-analyze-the-current-plan-output"')
+    expect(html).toContain("Inspect the existing plan prompts and completion flow.")
+    expect(html).toContain("<strong>plan artifact</strong>")
+    expect(html).toContain('href="https://example.com/summary"')
+    expect(html).toContain("This gives the user a clean browser view with anchors and recap links.")
+  })
+
+  test("renders an interactive plan page with comment inputs and actions", () => {
+    const document = SessionPlanHtml.buildPlanDocument(SAMPLE_PLAN, ".opencode/plans/example.md")
+    const html = SessionPlanHtml.renderInteractivePlanHtml({
+      document,
+      sessionID: SessionID.make("session_plan_html"),
+      replanUrl: "/session/session_plan_html/plan/replan",
+      proceedUrl: "/session/session_plan_html/plan/proceed",
+      token: "plan-token",
+    })
+
+    expect(html).toContain("Propose Revised Plan")
+    expect(html).toContain("Proceed")
+    expect(html).toContain('data-session-id="session_plan_html"')
+    expect(html).toContain(`data-plan-revision-id="${document.planRevisionID}"`)
+    expect(html).toContain('data-section-id="step-1-analyze-the-current-plan-output"')
+    expect(html).toContain("Save notes for this step")
+    expect(html).toContain("plan-token")
+  })
+
+  test("filters synthetic reminders and extracts markdown text", () => {
+    const parts: MessageV2.Part[] = [
+      {
+        id: PartID.ascending(),
+        messageID: MessageID.make("message_1"),
+        sessionID: SessionID.make("session_1"),
+        type: "text",
+        text: `<system-reminder>Do not render me</system-reminder>`,
+        synthetic: true,
+      },
+      {
+        id: PartID.ascending(),
+        messageID: MessageID.make("message_1"),
+        sessionID: SessionID.make("session_1"),
+        type: "tool",
+        tool: "todowrite",
+        callID: "call_1",
+        state: {
+          status: "completed",
+          input: {},
+          output: "ok",
+          metadata: {},
+          title: "updated todos",
+          time: { start: Date.now(), end: Date.now() },
+        },
+      } as MessageV2.ToolPart,
+      {
+        id: PartID.ascending(),
+        messageID: MessageID.make("message_1"),
+        sessionID: SessionID.make("session_1"),
+        type: "text",
+        text: "<system-reminder>Internal note</system-reminder>\n# Goal\nPlan content",
+      },
+    ]
+
+    expect(SessionPlanHtml.hasTodoWriteCompletion(parts)).toBe(true)
+    expect(SessionPlanHtml.markdownFromParts(parts)).toBe("# Goal\nPlan content")
+  })
+
+  test("opens only for plans with final structure and dedupes attachments per version", () => {
+    const ready = SAMPLE_PLAN
+    const incomplete = `# Goal\nDraft only\n\n# Plan Rationale\nStill exploring.`
+    const sessionID = SessionID.make("session_ready_plan")
+
+    expect(SessionPlanHtml.isPlanReadyForOpen(incomplete)).toBe(false)
+    expect(SessionPlanHtml.isPlanReadyForOpen(ready)).toBe(true)
+
