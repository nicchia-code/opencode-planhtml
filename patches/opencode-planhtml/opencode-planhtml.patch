@@ -0,0 +1,23 @@
+import type { SessionID } from "@/session/schema"
+
+type PlanServerInfo = {
+  url: string
+  token: string
+}
+
+let current: PlanServerInfo | undefined
+
+export function setPlanServer(info?: PlanServerInfo) {
+  current = info
+}
+
+export function getPlanServer() {
+  return current ? { ...current } : undefined
+}
+
+export function getPlanServerUrl(sessionID: SessionID) {
+  if (!current) return
+  const url = new URL(`/session/${sessionID}/plan`, current.url)
+  url.searchParams.set("token", current.token)
+  return url.toString()
+}

diff --git a/packages/opencode/src/session/plan-html.ts b/packages/opencode/src/session/plan-html.ts
new file mode 100644
index 000000000..7f06ae5ce
--- /dev/null
+++ b/packages/opencode/src/session/plan-html.ts
@@ -0,0 +1,627 @@
+import fs from "node:fs/promises"
+import { createHash } from "node:crypto"
+import { release } from "node:os"
+import path from "node:path"
+import { pathToFileURL } from "node:url"
+import { marked, type Tokens } from "marked"
+import open from "open"
+
+import { Flag } from "@/flag/flag"
+import { PartID, type MessageID, type SessionID } from "@/session/schema"
+import { Process } from "@/util/process"
+import { which } from "@/util/which"
+import { getPlanServerUrl } from "./plan-control"
+import { Session } from "./index"
+import type { MessageV2 } from "./message-v2"
+
+type Section = {
+  level: number
+  title: string
+  id: string
+  body: string
+}
+
+export type PlanSummaryRow = {
+  title: string
+  id: string
+  action: string
+  why: string
+}
+
+export type PlanSection = {
+  level: number
+  title: string
+  id: string
+  body: string
+  bodyHtml: string
+  action?: string
+  why?: string
+  filesTests?: string
+  commentable: boolean
+}
+
+export type PlanDocument = {
+  title: string
+  sourcePath: string
+  generatedAt: string
+  planRevisionID: string
+  leadHtml: string
+  sections: PlanSection[]
+  summaryRows: PlanSummaryRow[]
+}
+
+const SUMMARY_EXCLUDED_TITLES = new Set([
+  "goal",
+  "plan rationale",
+  "actions",
+  "verification",
+  "risks",
+  "risk",
+  "assumptions",
+  "open questions",
+  "questions",
+  "summary",
+  "summary table",
+  "plan summary",
+])
+
+const RENDER_OMITTED_TITLES = new Set(["summary", "summary table", "plan summary"])
+const SYSTEM_REMINDER_PATTERN = /<system-reminder>[\s\S]*?<\/system-reminder>/gi
+const openedPlanHashes = new Map<SessionID, string>()
+const announcedPlanHashes = new Map<SessionID, string>()
+
+function escapeHtml(value: string): string {
+  return value
+    .replace(/&/g, "&amp;")
+    .replace(/</g, "&lt;")
+    .replace(/>/g, "&gt;")
+    .replace(/\"/g, "&quot;")
+    .replace(/'/g, "&#39;")
+}
+
+function slugify(value: string): string {
+  const slug = value
+    .toLowerCase()
+    .replace(/[^a-z0-9]+/g, "-")
+    .replace(/^-+|-+$/g, "")
+
+  return slug || "section"
+}
+
+function uniqueId(input: string, seen: Map<string, number>): string {
+  const base = slugify(input)
+  const count = seen.get(base) ?? 0
+  seen.set(base, count + 1)
+  if (count === 0) return base
+  return `${base}-${count + 1}`
+}
+
+function paragraphs(value: string): string[] {
+  return value
+    .split(/\n\s*\n/g)
+    .map((item) => item.trim())
+    .filter(Boolean)
+    .map((item) => item.replace(/^[*-]\s+/gm, "").replace(/^\d+\.\s+/gm, "").trim())
+}
+
+function stripMarkdown(value: string): string {
+  return value
+    .replace(/`([^`]+)`/g, "$1")
+    .replace(/\*\*([^*]+)\*\*/g, "$1")
+    .replace(/__([^_]+)__/g, "$1")
+    .replace(/^#+\s+/gm, "")
+    .replace(/^>\s?/gm, "")
+    .replace(/\[(.*?)\]\((.*?)\)/g, "$1")
+    .trim()
+}
+
+function extractLabeledValue(body: string, label: string): string | undefined {
+  const match = body.match(new RegExp(`^${label}:\\s*(.+)$`, "im"))
+  const value = match?.[1]?.trim()
+  return value ? stripMarkdown(value) : undefined
+}
+
+function stripSystemReminders(value: string): string {
+  return value.replace(SYSTEM_REMINDER_PATTERN, "").trim()
+}
+
+function normalizePlanMarkdown(markdown: string): string {
+  return stripSystemReminders(markdown).trim()
+}
+
+function renderInline(value: string): string {
+  return escapeHtml(value).replace(/`([^`]+)`/g, "<code>$1</code>")
+}
+
+function renderMarkdownFragment(markdown: string): string {
+  const cleaned = stripSystemReminders(markdown)
+  if (!cleaned) return ""
+
+  const renderer = new marked.Renderer()
+  renderer.link = ({ href, title, text }: Tokens.Link) => {
+    const safeHref = escapeHtml(href)
+    const titleAttr = title ? ` title="${escapeHtml(title)}"` : ""
+    return `<a href="${safeHref}"${titleAttr} target="_blank" rel="noopener noreferrer">${text}</a>`
+  }
+
+  const rendered = marked(cleaned, {
+    gfm: true,
+    breaks: false,
+    renderer,
+  })
+
+  if (typeof rendered !== "string") {
+    throw new Error("Unexpected async markdown render")
+  }
+
+  return rendered
+}
+
+function parseSections(markdown: string): { title: string; lead: string; sections: Section[] } {
+  const lines = markdown.split(/\r?\n/)
+  const seen = new Map<string, number>()
+  let title = "Plan"
+  const lead: string[] = []
+  const sections: Section[] = []
+  let current: Section | undefined
+
+  const pushCurrent = () => {
+    if (!current) return
+    current.body = current.body.trim()
+    sections.push(current)
+    current = undefined
+  }
+
+  for (const line of lines) {
+    const headingMatch = line.match(/^(#{1,6})\s+(.+)$/)
+    if (headingMatch) {
+      const level = headingMatch[1].length
+      const headingTitle = headingMatch[2].trim()
+      if (level === 1 && title === "Plan" && !SUMMARY_EXCLUDED_TITLES.has(headingTitle.toLowerCase())) {
+        title = headingTitle
+      }
+      pushCurrent()
+      current = {
+        level,
+        title: headingTitle,
+        id: uniqueId(headingTitle, seen),
+        body: "",
+      }
+      continue
+    }
+
+    if (current) current.body += `${line}\n`
+    else lead.push(line)
+  }
+
+  pushCurrent()
+
+  return {
+    title,
+    lead: lead.join("\n").trim(),
+    sections,
+  }
+}
+
+function stepSections(sections: Section[]): Section[] {
+  const explicit = sections.filter((section) => section.level === 2 && /^(step|phase)\b/i.test(section.title))
+  if (explicit.length) return explicit
+
+  const inferred = sections.filter(
+    (section) => section.level === 2 && !SUMMARY_EXCLUDED_TITLES.has(section.title.trim().toLowerCase()),
+  )
+  if (inferred.length) return inferred
+
+  return sections.filter((section) => section.level === 3)
+}
+
+function summarizeSection(section: Section): { action: string; why: string } {
+  const action = extractLabeledValue(section.body, "What") ?? paragraphs(section.body)[0] ?? section.title
+  const why = extractLabeledValue(section.body, "Why") ?? paragraphs(section.body)[1] ?? "See section details"
+  return {
+    action: stripMarkdown(action),
+    why: stripMarkdown(why),
+  }
+}
