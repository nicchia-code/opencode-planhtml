+export type PlanUserSection = {
+  id: string
+  title: string
+}
+
+export type PlanUserHeadingNode = {
+  id: string
+  kind: "heading"
+  level: number
+  text: string
+  commentable: boolean
+}
+
+export type PlanUserParagraphNode = {
+  id: string
+  kind: "paragraph"
+  text: string
+  commentable: boolean
+}
+
+export type PlanUserListItem = {
+  id: string
+  text: string
+  commentable: boolean
+}
+
+export type PlanUserListNode = {
+  id: string
+  kind: "list"
+  ordered: boolean
+  items: PlanUserListItem[]
+  commentable: boolean
+}
+
+export type PlanUserFieldTextRow = {
+  id: string
+  label: "what" | "why"
+  kind: "text"
+  text: string
+  commentable: boolean
+}
+
+export type PlanUserFieldListRow = {
+  id: string
+  label: "files_tests"
+  kind: "list"
+  items: PlanUserListItem[]
+  commentable: boolean
+}
+
+export type PlanUserFieldRow = PlanUserFieldTextRow | PlanUserFieldListRow
+
+export type PlanUserFieldTableNode = {
+  id: string
+  kind: "field-table"
+  rows: PlanUserFieldRow[]
+  commentable: boolean
+}
+
+export type PlanUserToggleNode = {
+  id: string
+  kind: "toggle"
+  title: string
+  children: PlanUserNode[]
+  commentable: boolean
+}
+
+export type PlanUserNoteNode = {
+  id: string
+  kind: "note"
+  title: string
+  children: PlanUserNode[]
+  commentable: boolean
+}
+
+export type PlanUserNode =
+  | PlanUserHeadingNode
+  | PlanUserParagraphNode
+  | PlanUserListNode
+  | PlanUserFieldTableNode
+  | PlanUserToggleNode
+  | PlanUserNoteNode
+
+export type PlanUserDocument = {
+  title: string
+  sourcePath: string
+  generatedAt: string
+  planRevisionID: string
+  sections: PlanUserSection[]
+  nodes: PlanUserNode[]
+}

