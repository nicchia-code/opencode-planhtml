+    }
+
+    onCleanup(() => {
+      htmlStyle.backgroundColor = previousHtmlBackground
+      htmlStyle.colorScheme = previousHtmlColorScheme
+      bodyStyle.backgroundColor = previousBodyBackground
+      bodyStyle.minHeight = previousBodyMinHeight
+    })
+  })
+
+  createEffect(() => {
+    const pending = pendingRevisionID()
+    if (!pending) return
+
+    const interval = window.setInterval(() => {
+      void refetch()
+    }, 1500)
+
+    onCleanup(() => window.clearInterval(interval))
+  })
+
+  createEffect(() => {
