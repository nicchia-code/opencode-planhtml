diff --git a/packages/opencode/test/session/plan-user.test.ts b/packages/opencode/test/session/plan-user.test.ts
new file mode 100644
index 000000000..9e3dab1c1
--- /dev/null
+++ b/packages/opencode/test/session/plan-user.test.ts
@@ -0,0 +1,147 @@
+import { describe, expect, test } from "bun:test"
+
+import { Instance } from "../../src/project/instance"
+import { Session } from "../../src/session"
+import * as SessionPlanUser from "../../src/session/plan-user"
+import { tmpdir } from "../fixture/fixture"
+
+const SAMPLE_USER_PLAN = `# Goal
+Implement a richer plan review flow that users can understand without reading internal notes.
+
+# Piano Razionale
+I will keep the technical implementation rigorous, but I will present the user-facing plan as a guided review document with interactive disclosures.
+
+## What will change
+The plan page will become easier to review and comment.
+
+:::toggle[Editero questi file]
+- \`packages/opencode/src/session/plan-user.ts\`
+- \`packages/app/src/pages/session-plan.tsx\`
+:::
+
+## Why this is safer
+The user can inspect the work before build starts.
+
+:::note[Technical detail]
+The internal plan still exists, but this user plan must remain fully self-contained.
+:::
+`
+
+const SAMPLE_XML_USER_PLAN = `${SessionPlanUser.USER_PLAN_DELIMITER}
+
+<user_plan>
+  <title>Implement a richer plan review flow</title>
+  <goal>
+    <p>Explain the user-facing goal clearly.</p>
+  </goal>
+  <rationale>
+    <p>Keep the review readable and structured.</p>
+  </rationale>
+  <steps>
+    <step>
+      <title>Inspect the current plan output</title>
+      <what>Review the existing user-facing rendering.</what>
+      <why>We need a deterministic XML shape for What and Why.</why>
+      <files_tests>
+        <item>packages/opencode/src/session/plan-user.ts</item>
+        <item>packages/app/src/pages/session-plan.tsx</item>
+      </files_tests>
+      <details>
+        <item>Replace heuristic parsing with XML parsing.</item>
+      </details>
+    </step>
+  </steps>
+</user_plan>
+`
+
+describe("session.plan-user", () => {
+  test("builds a structured user plan document with toggle and note nodes", () => {
+    const document = SessionPlanUser.buildPlanUserDocument(SAMPLE_USER_PLAN, ".opencode/plans/example.user.md")
+
+    expect(document.planRevisionID).toHaveLength(64)
+    expect(document.sections.map((section) => section.title)).toEqual([
+      "Goal",
+      "Piano Razionale",
+      "What will change",
+      "Why this is safer",
+    ])
+    expect(document.nodes.some((node) => node.kind === "toggle")).toBe(true)
+    expect(document.nodes.some((node) => node.kind === "note")).toBe(true)
+    expect(document.nodes.some((node) => node.commentable && node.kind === "paragraph")).toBe(true)
+  })
+
+  test("renders toggle markup in the fallback HTML snapshot", () => {
+    const document = SessionPlanUser.buildPlanUserDocument(SAMPLE_USER_PLAN, ".opencode/plans/example.user.md")
+    const html = SessionPlanUser.renderPlanUserHtml(document)
+
+    expect(html).toContain("<details")
+    expect(html).toContain("Editero questi file")
+    expect(html).toContain("packages/app/src/pages/session-plan.tsx")
+  })
+
+  test("builds a structured user plan document from XML after the fixed delimiter", () => {
+    const document = SessionPlanUser.buildPlanUserDocument(SAMPLE_XML_USER_PLAN, ".opencode/plans/example.user.md")
+
+    expect(document.title).toBe("Implement a richer plan review flow")
+    expect(document.sections.map((section) => section.title)).toEqual(["Goal", "Piano Razionale", "Inspect the current plan output"])
+    expect(document.nodes.some((node) => node.kind === "field-table")).toBe(true)
+    expect(SessionPlanUser.flattenPlanUserTargets(document).some((target) => target.kind === "field-row")).toBe(true)
+  })
+
+  test("rejects plans that refer to a previous version", () => {
+    expect(() =>
+      SessionPlanUser.assertSelfContainedPlan(`# Goal\nSame as the previous plan, with one extra note.`),
+    ).toThrow(/self-contained/i)
+  })
+
+  test("derives a valid user-facing plan from the internal plan markdown", () => {
+    const derived = SessionPlanUser.deriveUserPlanMarkdown(`# Goal\n\nShip the fix.\n\n# Plan Rationale\n\nKeep the change small.\n\n# Actions\n\n## Step 1\nDo it.`)
+
+    expect(derived).toContain(SessionPlanUser.USER_PLAN_DELIMITER)
+    expect(derived).toContain("<user_plan>")
+    expect(derived).toContain("<goal>")
+    expect(derived).toContain("<rationale>")
+    expect(derived).toContain("<what>")
+    expect(derived).toContain("<why>")
+    expect(() => SessionPlanUser.buildPlanUserDocument(derived, ".opencode/plans/example.user.md")).not.toThrow()
+  })
+
+  test("sanitizes only system reminders from the user-facing plan", () => {
+    const sanitized = SessionPlanUser.sanitizeUserPlanMarkdown(`# Goal\n\nVisible.\n\n**Internal Plan**\n\n<system-reminder>hidden</system-reminder>\n\n# Actions\n\n## Step 1\nWhat: Visible row`)
+
+    expect(sanitized).toContain("# Goal")
+    expect(sanitized).toContain("**Internal Plan**")
+    expect(sanitized).toContain("# Actions")
+    expect(sanitized).toContain("## Step 1")
+    expect(sanitized).not.toContain("system-reminder")
+  })
+
+  test("isolates the user-facing section after the fixed delimiter", () => {
+    const sanitized = SessionPlanUser.sanitizeUserPlanMarkdown(`# Goal\n\nInternal details here.\n\n${SessionPlanUser.USER_PLAN_DELIMITER}\n\n<user_plan><goal><p>Visible user plan.</p></goal><rationale><p>Readable summary.</p></rationale><steps /></user_plan>`)
+
+    expect(sanitized).toBe(`<user_plan><goal><p>Visible user plan.</p></goal><rationale><p>Readable summary.</p></rationale><steps /></user_plan>`)
+  })
+
+  test("renders markdown bold in the fallback html snapshot", () => {
+    const document = SessionPlanUser.buildPlanUserDocument(`# Goal\n\nShip **this exact fix**.\n\n# Piano Razionale\n\nKeep **Files/Tests** readable.`, ".opencode/plans/example.user.md")
+    const html = SessionPlanUser.renderPlanUserHtml(document)
+
+    expect(html).toContain("<strong>this exact fix</strong>")
+    expect(html).toContain("<strong>Files/Tests</strong>")
+  })
+
+  test("stores user-plan artifacts next to the internal plan", async () => {
+    await using tmp = await tmpdir({ git: true })
+    await Instance.provide({
+      directory: tmp.path,
+      fn: async () => {
+        const input = { slug: "playful-comet", time: { created: 1775063234089 } }
+
+        expect(Session.plan(input)).toMatch(/\.opencode\/plans\/1775063234089-playful-comet\.md$/)
+        expect(Session.planUser(input)).toMatch(/\.opencode\/plans\/1775063234089-playful-comet\.user\.md$/)
+        expect(Session.planUserHtml(input)).toMatch(/\.opencode\/plans\/1775063234089-playful-comet\.user\.html$/)
+        expect(Session.planUserData(input)).toMatch(/\.opencode\/plans\/1775063234089-playful-comet\.user\.json$/)
+      },
+    })
+  })
+})
