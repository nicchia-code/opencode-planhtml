+    async (id) => {
+      return api<PlanDocumentResponse>(`/session/${id}/plan/user`)
+    },
+  )
+  const storageKey = createMemo(() => {
+    const revision = plan()?.document.planRevisionID
+    if (!revision || !sessionID()) return undefined
