diff --git a/packages/opencode/src/session/plan-html.ts b/packages/opencode/src/session/plan-html.ts
new file mode 100644
index 0000000..7de4856
--- /dev/null
+++ b/packages/opencode/src/session/plan-html.ts
@@ -0,0 +1,437 @@
+import fs from "node:fs/promises"
+import { createHash } from "node:crypto"
+import { release } from "node:os"
+import path from "node:path"
+import { pathToFileURL } from "node:url"
+import { marked, type Tokens } from "marked"
+import open from "open"
+
+import { Flag } from "@/flag/flag"
+import { PartID, type MessageID, type SessionID } from "@/session/schema"
+import { Process } from "@/util/process"
+import { which } from "@/util/which"
+import { Session } from "./index"
+import type { MessageV2 } from "./message-v2"
+
+type Section = {
+  level: number
+  title: string
+  id: string
+  body: string
+}
+
+const SUMMARY_EXCLUDED_TITLES = new Set([
+  "goal",
+  "plan rationale",
+  "actions",
+  "verification",
+  "risks",
+  "risk",
+  "assumptions",
+  "open questions",
+  "questions",
+  "summary",
+  "summary table",
+  "plan summary",
+])
+
+const RENDER_OMITTED_TITLES = new Set(["summary", "summary table", "plan summary"])
+const SYSTEM_REMINDER_PATTERN = /<system-reminder>[\s\S]*?<\/system-reminder>/gi
+const openedPlanHashes = new Map<SessionID, string>()
+const announcedPlanHashes = new Map<SessionID, string>()
+
+function escapeHtml(value: string): string {
+  return value
+    .replace(/&/g, "&amp;")
+    .replace(/</g, "&lt;")
+    .replace(/>/g, "&gt;")
+    .replace(/\"/g, "&quot;")
+    .replace(/'/g, "&#39;")
+}
+
+function slugify(value: string): string {
+  const slug = value
+    .toLowerCase()
+    .replace(/[^a-z0-9]+/g, "-")
+    .replace(/^-+|-+$/g, "")
+
+  return slug || "section"
+}
+
+function uniqueId(input: string, seen: Map<string, number>): string {
+  const base = slugify(input)
+  const count = seen.get(base) ?? 0
+  seen.set(base, count + 1)
+  if (count === 0) return base
+  return `${base}-${count + 1}`
+}
+
+function paragraphs(value: string): string[] {
+  return value
+    .split(/\n\s*\n/g)
+    .map((item) => item.trim())
+    .filter(Boolean)
+    .map((item) => item.replace(/^[*-]\s+/gm, "").replace(/^\d+\.\s+/gm, "").trim())
+}
+
+function stripMarkdown(value: string): string {
+  return value
+    .replace(/`([^`]+)`/g, "$1")
+    .replace(/\*\*([^*]+)\*\*/g, "$1")
+    .replace(/__([^_]+)__/g, "$1")
+    .replace(/^#+\s+/gm, "")
+    .replace(/^>\s?/gm, "")
+    .replace(/\[(.*?)\]\((.*?)\)/g, "$1")
+    .trim()
+}
+
+function extractLabeledValue(body: string, label: string): string | undefined {
+  const match = body.match(new RegExp(`^${label}:\\s*(.+)$`, "im"))
+  const value = match?.[1]?.trim()
+  return value ? stripMarkdown(value) : undefined
+}
+
+function stripSystemReminders(value: string): string {
+  return value.replace(SYSTEM_REMINDER_PATTERN, "").trim()
+}
+
+function normalizePlanMarkdown(markdown: string): string {
+  return stripSystemReminders(markdown).trim()
+}
+
+function renderInline(value: string): string {
+  return escapeHtml(value).replace(/`([^`]+)`/g, "<code>$1</code>")
+}
+
+function renderMarkdownFragment(markdown: string): string {
+  const cleaned = stripSystemReminders(markdown)
+  if (!cleaned) return ""
+
+  const renderer = new marked.Renderer()
+  renderer.link = ({ href, title, text }: Tokens.Link) => {
+    const safeHref = escapeHtml(href)
+    const titleAttr = title ? ` title="${escapeHtml(title)}"` : ""
+    return `<a href="${safeHref}"${titleAttr} target="_blank" rel="noopener noreferrer">${text}</a>`
+  }
+
+  const rendered = marked(cleaned, {
+    gfm: true,
+    breaks: false,
+    renderer,
+  })
+
+  if (typeof rendered !== "string") {
+    throw new Error("Unexpected async markdown render")
+  }
+
+  return rendered
+}
+
+function parseSections(markdown: string): { title: string; lead: string; sections: Section[] } {
+  const lines = markdown.split(/\r?\n/)
+  const seen = new Map<string, number>()
+  let title = "Plan"
+  const lead: string[] = []
+  const sections: Section[] = []
+  let current: Section | undefined
+
+  const pushCurrent = () => {
+    if (!current) return
+    current.body = current.body.trim()
+    sections.push(current)
+    current = undefined
+  }
+
+  for (const line of lines) {
+    const headingMatch = line.match(/^(#{1,6})\s+(.+)$/)
+    if (headingMatch) {
+      const level = headingMatch[1].length
+      const headingTitle = headingMatch[2].trim()
+      if (level === 1 && title === "Plan" && !SUMMARY_EXCLUDED_TITLES.has(headingTitle.toLowerCase())) {
+        title = headingTitle
+      }
+      pushCurrent()
+      current = {
+        level,
+        title: headingTitle,
+        id: uniqueId(headingTitle, seen),
+        body: "",
+      }
+      continue
+    }
+
+    if (current) current.body += `${line}\n`
+    else lead.push(line)
+  }
+
+  pushCurrent()
+
+  return {
+    title,
+    lead: lead.join("\n").trim(),
+    sections,
+  }
+}
+
+function stepSections(sections: Section[]): Section[] {
+  const explicit = sections.filter((section) => section.level === 2 && /^(step|phase)\b/i.test(section.title))
+  if (explicit.length) return explicit
+
+  const inferred = sections.filter(
+    (section) => section.level === 2 && !SUMMARY_EXCLUDED_TITLES.has(section.title.trim().toLowerCase()),
+  )
+  if (inferred.length) return inferred
+
+  return sections.filter((section) => section.level === 3)
+}
+
+function summarizeSection(section: Section): { action: string; why: string } {
+  const action = extractLabeledValue(section.body, "What") ?? paragraphs(section.body)[0] ?? section.title
+  const why = extractLabeledValue(section.body, "Why") ?? paragraphs(section.body)[1] ?? "See section details"
+  return {
+    action: stripMarkdown(action),
+    why: stripMarkdown(why),
+  }
+}
+
+function fallbackTitle(sourcePath: string): string {
+  const base = path.basename(sourcePath, path.extname(sourcePath)).replace(/^\d+-/, "")
+  const normalized = base.replace(/[-_]+/g, " ").trim()
+  return normalized || "Plan"
+}
+
+function htmlTemplate(input: {
+  title: string
+  leadHtml: string
+  sections: Section[]
+  summaryRows: Array<{ title: string; id: string; action: string; why: string }>
+  sourcePath: string
+  generatedAt: string
+}) {
+  const sectionHtml = input.sections
+    .filter((section) => !RENDER_OMITTED_TITLES.has(section.title.trim().toLowerCase()))
+    .map((section) => {
+      const level = Math.min(Math.max(section.level, 2), 4)
+      return [
+        `<section class="plan-section" id="${section.id}">`,
+        `<h${level}><a href="#${section.id}">${renderInline(section.title)}</a></h${level}>`,
+        renderMarkdownFragment(section.body),
+        `</section>`,
+      ].join("\n")
+    })
+    .join("\n")
+
+  const summaryTable = input.summaryRows.length
+    ? [
+        `<section class="plan-section" id="plan-summary">`,
+        `<h2><a href="#plan-summary">Plan Summary</a></h2>`,
+        `<table>`,
+        `<thead><tr><th>Step</th><th>Action</th><th>Why</th><th>Link</th></tr></thead>`,
+        `<tbody>`,
+        ...input.summaryRows.map(
+          (row) =>
+            `<tr><td>${renderInline(row.title)}</td><td>${renderInline(row.action)}</td><td>${renderInline(row.why)}</td><td><a href="#${row.id}">Jump</a></td></tr>`,
+        ),
+        `</tbody>`,
+        `</table>`,
+        `</section>`,
+      ].join("\n")
+    : ""
+
+  return [
+    "<!doctype html>",
+    '<html lang="en">',
+    "<head>",
+    '  <meta charset="utf-8">',
+    '  <meta name="viewport" content="width=device-width, initial-scale=1">',
+    `  <title>${escapeHtml(input.title)}</title>`,
+    "  <style>",
+    "    :root { color-scheme: light dark; --bg: #f6f1e8; --panel: #fffdf9; --text: #1f1a14; --muted: #6f6558; --border: #d7c8b2; --accent: #8a4b11; --accent-soft: #f2dec6; --code: #f0e6d8; }",
+    "    @media (prefers-color-scheme: dark) { :root { --bg: #181511; --panel: #211b15; --text: #f5eee5; --muted: #c6b39a; --border: #4a3b2b; --accent: #f0a35a; --accent-soft: #33261a; --code: #2a221a; } }",
+    "    * { box-sizing: border-box; }",
+    "    body { margin: 0; font-family: Georgia, 'Times New Roman', serif; background: linear-gradient(180deg, var(--bg), color-mix(in srgb, var(--bg) 70%, white 30%)); color: var(--text); }",
+    "    main { max-width: 980px; margin: 0 auto; padding: 40px 20px 72px; }",
+    "    header { margin-bottom: 32px; padding: 24px 28px; border: 1px solid var(--border); border-radius: 20px; background: var(--panel); box-shadow: 0 16px 50px rgba(0, 0, 0, 0.08); }",
+    "    h1, h2, h3, h4 { font-family: 'Palatino Linotype', 'Book Antiqua', Palatino, serif; line-height: 1.15; }",
+    "    h1 { margin: 0 0 12px; font-size: clamp(2rem, 3vw, 3rem); }",
+    "    h2 { margin: 0 0 14px; font-size: 1.6rem; }",
+    "    h3 { margin: 0 0 12px; font-size: 1.2rem; }",
+    "    p, li { line-height: 1.65; }",
+    "    code { font-family: 'SFMono-Regular', 'Consolas', monospace; background: var(--code); padding: 0.15rem 0.35rem; border-radius: 6px; }",
+    "    pre { overflow-x: auto; padding: 16px; border-radius: 14px; background: var(--code); border: 1px solid var(--border); }",
+    "    pre code { padding: 0; background: transparent; }",
+    "    a { color: var(--accent); }",
+    "    .meta { color: var(--muted); font-size: 0.95rem; }",
+    "    .lead { margin-top: 18px; }",
+    "    .plan-section { margin-top: 24px; padding: 24px 28px; border: 1px solid var(--border); border-radius: 20px; background: var(--panel); box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05); }",
+    "    table { width: 100%; border-collapse: collapse; margin-top: 12px; }",
+    "    th, td { text-align: left; padding: 12px 10px; border-bottom: 1px solid var(--border); vertical-align: top; }",
+    "    th { font-size: 0.9rem; letter-spacing: 0.04em; text-transform: uppercase; color: var(--muted); }",
+    "    ul, ol { padding-left: 1.5rem; }",
+    "    @media (max-width: 720px) { main { padding: 20px 14px 40px; } header, .plan-section { padding: 18px; } table, thead, tbody, tr, th, td { display: block; } th { padding-bottom: 0; } td { padding-top: 6px; } }",
+    "  </style>",
+    "</head>",
+    "<body>",
+    "  <main>",
+    "    <header>",
+    `      <p class="meta">Generated ${escapeHtml(input.generatedAt)}</p>`,
+    `      <h1>${renderInline(input.title)}</h1>`,
+    `      <p class="meta">Source plan: <code>${escapeHtml(input.sourcePath)}</code></p>`,
+    input.leadHtml ? `      <div class="lead">${input.leadHtml}</div>` : "",
+    "    </header>",
+    summaryTable,
+    sectionHtml,
+    "  </main>",
+    "</body>",
+    "</html>",
+  ].join("\n")
+}
+
+function isWslEnvironment(env = process.env): boolean {
+  return process.platform === "linux" && (release().includes("WSL") || Boolean(env["WSL_DISTRO_NAME"]))
+}
+
+export function hasTodoWriteCompletion(parts: MessageV2.Part[]): boolean {
+  return parts.some((part) => part.type === "tool" && part.tool === "todowrite" && part.state.status === "completed")
+}
+
+export function markdownFromParts(parts: MessageV2.Part[]): string {
+  return parts
+    .filter((part): part is MessageV2.TextPart => part.type === "text" && !part.synthetic && !part.ignored)
+    .map((part) => normalizePlanMarkdown(part.text))
+    .map((part) => part.trim())
+    .filter(Boolean)
+    .join("\n\n")
+    .trim()
+}
+
+export function isPlanReadyForOpen(markdown: string): boolean {
+  const normalized = normalizePlanMarkdown(markdown)
+  if (!normalized) return false
+
+  return /^#\s+Goal\b/im.test(normalized) && /^#\s+Actions\b/im.test(normalized) && /^##\s+(Step|Phase)\b/im.test(normalized)
+}
+
+function planHash(markdown: string): string {
+  return createHash("sha256").update(normalizePlanMarkdown(markdown)).digest("hex")
+}
+
+export function shouldAttachPlanHtml(sessionID: SessionID, hash: string, ready: boolean): boolean {
+  if (!ready) return false
+  const previous = announcedPlanHashes.get(sessionID)
+  if (previous === hash) return false
+  announcedPlanHashes.set(sessionID, hash)
+  return true
+}
+
+export function renderPlanHtml(markdown: string, sourcePath: string): string {
+  const parsed = parseSections(markdown)
+  const summaryRows = stepSections(parsed.sections).map((section) => {
+    const summary = summarizeSection(section)
+    return {
+      title: section.title,
+      id: section.id,
+      action: summary.action,
+      why: summary.why,
+    }
+  })
+
+  return htmlTemplate({
+    title: parsed.title === "Plan" ? fallbackTitle(sourcePath) : parsed.title,
+    leadHtml: parsed.lead ? renderMarkdownFragment(parsed.lead) : "",
+    sections: parsed.sections,
+    summaryRows,
+    sourcePath,
+    generatedAt: new Date().toLocaleString(),
+  })
+}
+
+export function htmlAttachment(input: { htmlPath: string; messageID: MessageID; sessionID: SessionID }): MessageV2.FilePart {
+  return {
+    id: PartID.ascending(),
+    messageID: input.messageID,
+    sessionID: input.sessionID,
+    type: "file",
+    filename: path.basename(input.htmlPath),
+    mime: "text/html",
+    url: pathToFileURL(input.htmlPath).href,
+  }
+}
+
+async function openHtmlFile(htmlPath: string): Promise<boolean> {
+  if (Flag.OPENCODE_DISABLE_PLAN_HTML_AUTO_OPEN || Boolean(process.env["CI"])) return false
+
+  if (isWslEnvironment()) {
+    if (which("wslview")) {
+      const result = await Process.run(["wslview", htmlPath], { nothrow: true })
+      if (result.code === 0) return true
+    }
+
+    if (which("wslpath") && which("powershell.exe")) {
+      const windowsPath = await Process.text(["wslpath", "-w", htmlPath], { nothrow: true })
+      const target = windowsPath.text.trim()
+      if (windowsPath.code === 0 && target) {
+        const command = `Start-Process -FilePath '${target.replace(/'/g, "''")}'`
+        const result = await Process.run(["powershell.exe", "-NoProfile", "-Command", command], { nothrow: true })
+        if (result.code === 0) return true
+      }
+    }
+  }
+
+  try {
+    await open(htmlPath)
+    return true
+  } catch {
+    return false
+  }
+}
+
+async function writeHtml(htmlPath: string, html: string) {
+  await fs.mkdir(path.dirname(htmlPath), { recursive: true })
+  await fs.writeFile(htmlPath, html, "utf8")
+}
+
+export async function renderPlanArtifacts(input: {
+  session: Session.Info
+  markdown: string
+  persistMarkdown?: boolean
+  autoOpen?: boolean
+}) {
+  const markdownPath = Session.plan(input.session)
+  const htmlPath = Session.planHtml(input.session)
+  const hash = planHash(input.markdown)
+  const ready = isPlanReadyForOpen(input.markdown)
+
+  if (input.persistMarkdown ?? true) {
+    await fs.mkdir(path.dirname(markdownPath), { recursive: true })
+    await fs.writeFile(markdownPath, input.markdown, "utf8")
+  }
+
+  const html = renderPlanHtml(input.markdown, markdownPath)
+  await writeHtml(htmlPath, html)
+
+  let opened = false
+  if (input.autoOpen !== false && ready && openedPlanHashes.get(input.session.id) !== hash) {
+    opened = await openHtmlFile(htmlPath)
+    if (opened) openedPlanHashes.set(input.session.id, hash)
+  }
+
+  return {
+    markdownPath,
+    htmlPath,
+    hash,
+    ready,
+    opened,
+  }
+}
+
+export async function renderExistingPlanArtifacts(input: { session: Session.Info; autoOpen?: boolean }) {
+  const markdownPath = Session.plan(input.session)
+  const markdown = await fs.readFile(markdownPath, "utf8")
+  return renderPlanArtifacts({
+    session: input.session,
+    markdown,
+    persistMarkdown: false,
+    autoOpen: input.autoOpen,
+  })
+}

