+  return [
+    "<!doctype html>",
+    '<html lang="en">',
+    "<head>",
+    '  <meta charset="utf-8">',
+    '  <meta name="viewport" content="width=device-width, initial-scale=1">',
+    `  <title>${escapeHtml(input.document.title)}</title>`,
+    "  <style>",
+    planStyles(),
+    "  </style>",
+    "</head>",
+    "<body>",
+    "  <main>",
+    "    <header>",
+    `      <p class="meta">Generated ${escapeHtml(input.document.generatedAt)}</p>`,
+    `      <h1>${renderInline(input.document.title)}</h1>`,
+    `      <p class="meta">Source plan: <code>${escapeHtml(input.document.sourcePath)}</code></p>`,
+    input.document.leadHtml ? `      <div class="lead">${input.document.leadHtml}</div>` : "",
+    input.liveUrl
+      ? `      <p class="banner"><a href="${escapeHtml(input.liveUrl)}">Open interactive plan</a> to comment on steps, propose a revision, or proceed directly into build mode.</p>`
+      : "",
+    "    </header>",
+    summaryTable,
+    sectionHtml,
+    "  </main>",
+    "</body>",
+    "</html>",
+  ].join("\n")
+}
+
+export function renderInteractivePlanHtml(input: {
+  document: PlanDocument
+  sessionID: SessionID
+  replanUrl: string
+  proceedUrl: string
+  token?: string
+}) {
+  const sections = input.document.sections
+    .map((section) => {
+      const level = Math.min(Math.max(section.level, 2), 4)
+      const noteBlock = section.commentable
+        ? [
+            `<div class="note-block">`,
+            `<label for="note-${section.id}">Save notes for this step</label>`,
+            `<textarea id="note-${section.id}" data-note-input data-section-id="${section.id}" data-section-title="${escapeHtml(section.title)}" placeholder="Describe exactly what should change in this step."></textarea>`,
+            `</div>`,
+          ].join("\n")
+        : ""
+      return [
+        `<section class="plan-section" id="${section.id}"${section.commentable ? ` data-section-id="${section.id}"` : ""}>`,
+        `<h${level}><a href="#${section.id}">${renderInline(section.title)}</a></h${level}>`,
+        renderSectionMeta(section),
+        section.bodyHtml,
+        noteBlock,
+        `</section>`,
+      ].join("\n")
+    })
+    .join("\n")
+
+  const state = {
+    sessionID: input.sessionID,
+    planRevisionID: input.document.planRevisionID,
+    replanUrl: input.replanUrl,
+    proceedUrl: input.proceedUrl,
+    token: input.token,
+    storageKey: `opencode-plan-comments:${input.sessionID}:${input.document.planRevisionID}`,
+  }
+
+  return [
+    "<!doctype html>",
+    '<html lang="en">',
+    "<head>",
+    '  <meta charset="utf-8">',
+    '  <meta name="viewport" content="width=device-width, initial-scale=1">',
+    `  <title>${escapeHtml(input.document.title)}</title>`,
+    "  <style>",
+    planStyles(),
+    "  </style>",
+    "</head>",
+    `<body data-session-id="${input.sessionID}" data-plan-revision-id="${input.document.planRevisionID}">`,
+    "  <main>",
+    "    <header>",
+    `      <p class="meta">Live plan review</p>`,
+    `      <h1>${renderInline(input.document.title)}</h1>`,
+    `      <p class="meta">Plan revision <code>${escapeHtml(input.document.planRevisionID.slice(0, 12))}</code> · Source <code>${escapeHtml(input.document.sourcePath)}</code></p>`,
+    input.document.leadHtml ? `      <div class="lead">${input.document.leadHtml}</div>` : "",
+    "    </header>",
+    renderSummaryTable(input.document.summaryRows),
+    sections,
+    '    <section class="actions" aria-label="Plan actions">',
+    '      <div class="actions-copy">',
+    '        <strong>Review the plan, leave notes where needed, then send one revision request.</strong>',
+    '        <span class="meta" data-plan-status>Ready to review.</span>',
+    '      </div>',
+    '      <div class="actions-controls">',
+    '        <button class="primary" type="button" data-action="replan">Propose Revised Plan</button>',
+    '        <button type="button" data-action="proceed">Proceed</button>',
+    '      </div>',
+    '    </section>',
+    "  </main>",
+    "  <script>",
+    `    const PLAN_PAGE = ${serializeForScript(state)};`,
+    `    const noteInputs = Array.from(document.querySelectorAll('[data-note-input]'));`,
+    `    const statusEl = document.querySelector('[data-plan-status]');`,
+    `    const replanButton = document.querySelector('[data-action="replan"]');`,
+    `    const proceedButton = document.querySelector('[data-action="proceed"]');`,
+    "    const readDraft = () => { try { return JSON.parse(localStorage.getItem(PLAN_PAGE.storageKey) || '{}'); } catch { return {}; } };",
+    "    const writeDraft = (value) => localStorage.setItem(PLAN_PAGE.storageKey, JSON.stringify(value));",
+    "    const setStatus = (message, error = false) => { if (!statusEl) return; statusEl.textContent = message; statusEl.classList.toggle('status-error', error); };",
+    "    const collectComments = () => noteInputs.map((input) => ({ sectionID: input.dataset.sectionId || '', title: input.dataset.sectionTitle || '', note: input.value.trim() })).filter((item) => item.note.length > 0);",
+    "    const syncDraft = () => { const next = Object.fromEntries(noteInputs.map((input) => [input.dataset.sectionId || '', input.value])); writeDraft(next); };",
+    "    const setBusy = (busy) => { if (replanButton) replanButton.disabled = busy; if (proceedButton) proceedButton.disabled = busy; };",
+    "    const headers = () => { const result = { 'content-type': 'application/json' }; if (PLAN_PAGE.token) result['x-opencode-plan-token'] = PLAN_PAGE.token; return result; };",
+    "    const send = async (url, body) => { const res = await fetch(url, { method: 'POST', headers: headers(), body: JSON.stringify(body) }); if (!res.ok) { const payload = await res.json().catch(() => ({})); throw new Error(payload.error || `request_failed_${res.status}`); } return res.json().catch(() => ({})); };",
+    "    const draft = readDraft();",
+    "    for (const input of noteInputs) { const key = input.dataset.sectionId || ''; input.value = typeof draft[key] === 'string' ? draft[key] : ''; input.addEventListener('input', syncDraft); }",
+    "    replanButton?.addEventListener('click', async () => { const comments = collectComments(); if (!comments.length) { setStatus('Add at least one note before requesting a revised plan.', true); return; } setBusy(true); setStatus('Sending revision request...'); try { await send(PLAN_PAGE.replanUrl, { planRevisionID: PLAN_PAGE.planRevisionID, comments }); localStorage.removeItem(PLAN_PAGE.storageKey); for (const input of noteInputs) input.value = ''; setStatus('Revision request sent. OpenCode is drafting a new plan.'); } catch (error) { setStatus(error instanceof Error ? error.message : String(error), true); } finally { setBusy(false); } });",
+    "    proceedButton?.addEventListener('click', async () => { setBusy(true); setStatus('Approving plan and switching to build...'); try { await send(PLAN_PAGE.proceedUrl, { planRevisionID: PLAN_PAGE.planRevisionID }); setStatus('Proceed sent. OpenCode is switching to build mode.'); } catch (error) { setStatus(error instanceof Error ? error.message : String(error), true); } finally { setBusy(false); } });",
+    "  </script>",
+    "</body>",
+    "</html>",
+  ].join("\n")
+}
+
+function isWslEnvironment(env = process.env): boolean {
+  return process.platform === "linux" && (release().includes("WSL") || Boolean(env["WSL_DISTRO_NAME"]))
+}
+
+export function hasTodoWriteCompletion(parts: MessageV2.Part[]): boolean {
+  return parts.some((part) => part.type === "tool" && part.tool === "todowrite" && part.state.status === "completed")
+}
+
+export function markdownFromParts(parts: MessageV2.Part[]): string {
+  return parts
+    .filter((part): part is MessageV2.TextPart => part.type === "text" && !part.synthetic && !part.ignored)
+    .map((part) => normalizePlanMarkdown(part.text))
+    .map((part) => part.trim())
+    .filter(Boolean)
+    .join("\n\n")
+    .trim()
+}
+
+export function isPlanReadyForOpen(markdown: string): boolean {
+  const normalized = normalizePlanMarkdown(markdown)
+  if (!normalized) return false
+
+  return /^#\s+Goal\b/im.test(normalized) && /^#\s+Actions\b/im.test(normalized) && /^##\s+(Step|Phase)\b/im.test(normalized)
+}
+
+function planHash(markdown: string): string {
+  return createHash("sha256").update(normalizePlanMarkdown(markdown)).digest("hex")
+}
+
+export function buildPlanDocument(markdown: string, sourcePath: string): PlanDocument {
+  const parsed = parseSections(markdown)
+  const commentable = new Set(stepSections(parsed.sections).map((section) => section.id))
+  const sections = parsed.sections
+    .filter((section) => !RENDER_OMITTED_TITLES.has(section.title.trim().toLowerCase()))
+    .map<PlanSection>((section) => {
+      const summary = summarizeSection(section)
+      return {
+        level: section.level,
+        title: section.title,
+        id: section.id,
+        body: section.body,
+        bodyHtml: renderMarkdownFragment(section.body),
+        action: extractLabeledValue(section.body, "What") ?? summary.action,
+        why: extractLabeledValue(section.body, "Why") ?? summary.why,
+        filesTests: extractLabeledValue(section.body, "Files/Tests"),
+        commentable: commentable.has(section.id),
+      }
+    })
+  const summaryRows = sections
+    .filter((section) => section.commentable)
+    .map((section) => ({
+      title: section.title,
+      id: section.id,
+      action: section.action ?? section.title,
+      why: section.why ?? "See step details",
+    }))
+
+  return {
+    title: parsed.title === "Plan" ? fallbackTitle(sourcePath) : parsed.title,
+    sourcePath,
+    generatedAt: new Date().toLocaleString(),
+    planRevisionID: planHash(markdown),
+    leadHtml: parsed.lead ? renderMarkdownFragment(parsed.lead) : "",
+    sections,
+    summaryRows,
+  }
+}
+
+export function shouldAttachPlanHtml(sessionID: SessionID, hash: string, ready: boolean): boolean {
+  if (!ready) return false
+  const previous = announcedPlanHashes.get(sessionID)
+  if (previous === hash) return false
+  announcedPlanHashes.set(sessionID, hash)
+  return true
+}
+
+export function renderPlanHtml(markdown: string, sourcePath: string, options?: { liveUrl?: string }): string {
+  const document = buildPlanDocument(markdown, sourcePath)
+  return snapshotTemplate({
+    document,
+    liveUrl: options?.liveUrl,
+  })
+}
+
+export function htmlAttachment(input: { htmlPath: string; messageID: MessageID; sessionID: SessionID }): MessageV2.FilePart {
+  return {
+    id: PartID.ascending(),
+    messageID: input.messageID,
+    sessionID: input.sessionID,
+    type: "file",
+    filename: path.basename(input.htmlPath),
+    mime: "text/html",
+    url: pathToFileURL(input.htmlPath).href,
+  }
+}
+
+async function openTarget(target: string): Promise<boolean> {
+  if (Flag.OPENCODE_DISABLE_PLAN_HTML_AUTO_OPEN || Boolean(process.env["CI"])) return false
+
+  if (isWslEnvironment()) {
+    if (which("wslview")) {
+      const result = await Process.run(["wslview", target], { nothrow: true })
+      if (result.code === 0) return true
+    }
+
+    if (!/^https?:\/\//.test(target) && which("wslpath") && which("powershell.exe")) {
+      const windowsPath = await Process.text(["wslpath", "-w", target], { nothrow: true })
+      const windowsTarget = windowsPath.text.trim()
+      if (windowsPath.code === 0 && windowsTarget) {
+        const command = `Start-Process -FilePath '${windowsTarget.replace(/'/g, "''")}'`
+        const result = await Process.run(["powershell.exe", "-NoProfile", "-Command", command], { nothrow: true })
+        if (result.code === 0) return true
+      }
+    }
+  }
+
+  try {
+    await open(target)
+    return true
+  } catch {
+    return false
+  }
+}
+
+async function writeHtml(htmlPath: string, html: string) {
+  await fs.mkdir(path.dirname(htmlPath), { recursive: true })
+  await fs.writeFile(htmlPath, html, "utf8")
+}
+
+export async function renderPlanArtifacts(input: {
+  session: Session.Info
+  markdown: string
+  persistMarkdown?: boolean
+  autoOpen?: boolean
+}) {
+  const markdownPath = Session.plan(input.session)
+  const htmlPath = Session.planHtml(input.session)
+  const hash = planHash(input.markdown)
+  const ready = isPlanReadyForOpen(input.markdown)
+  const liveUrl = ready ? getPlanServerUrl(input.session.id) : undefined
+
+  if (input.persistMarkdown ?? true) {
+    await fs.mkdir(path.dirname(markdownPath), { recursive: true })
+    await fs.writeFile(markdownPath, input.markdown, "utf8")
+  }
+
+  const html = renderPlanHtml(input.markdown, markdownPath, { liveUrl })
+  await writeHtml(htmlPath, html)
+
+  let opened = false
+  if (input.autoOpen !== false && ready && openedPlanHashes.get(input.session.id) !== hash) {
+    opened = await openTarget(liveUrl ?? htmlPath)
+    if (opened) openedPlanHashes.set(input.session.id, hash)
+  }
+
+  return {
+    markdownPath,
+    htmlPath,
+    liveUrl,
+    hash,
+    ready,
+    opened,
+  }
+}
+
+export async function renderExistingPlanArtifacts(input: { session: Session.Info; autoOpen?: boolean }) {
+  const markdownPath = Session.plan(input.session)
+  const markdown = await fs.readFile(markdownPath, "utf8")
+  return renderPlanArtifacts({
+    session: input.session,
+    markdown,
+    persistMarkdown: false,
+    autoOpen: input.autoOpen,
+  })
+}

