+  ].join("\n")
+}
+
+function renderSummaryTable(summaryRows: PlanSummaryRow[]) {
+  if (!summaryRows.length) return ""
+  return [
+    `<section class="plan-section" id="plan-summary">`,
+    `<h2><a href="#plan-summary">Plan Summary</a></h2>`,
+    `<table>`,
+    `<thead><tr><th>Step</th><th>Action</th><th>Why</th><th>Link</th></tr></thead>`,
+    `<tbody>`,
+    ...summaryRows.map(
+      (row) =>
+        `<tr><td>${renderInline(row.title)}</td><td>${renderInline(row.action)}</td><td>${renderInline(row.why)}</td><td><a href="#${row.id}">Jump</a></td></tr>`,
+    ),
+    `</tbody>`,
+    `</table>`,
+    `</section>`,
+  ].join("\n")
+}
+
+function renderSectionMeta(section: PlanSection) {
+  const chips = [
+    section.action ? `<span class="chip"><strong>What</strong> ${renderInline(section.action)}</span>` : "",
+    section.why ? `<span class="chip"><strong>Why</strong> ${renderInline(section.why)}</span>` : "",
+    section.filesTests ? `<span class="chip"><strong>Files/Tests</strong> ${renderInline(section.filesTests)}</span>` : "",
+  ].filter(Boolean)
+  if (!chips.length) return ""
+  return `<div class="section-meta">${chips.join("")}</div>`
+}
+
+function renderSnapshotSections(sections: PlanSection[]) {
+  return sections
+    .map((section) => {
+      const level = Math.min(Math.max(section.level, 2), 4)
+      return [
+        `<section class="plan-section" id="${section.id}">`,
+        `<h${level}><a href="#${section.id}">${renderInline(section.title)}</a></h${level}>`,
+        renderSectionMeta(section),
+        section.bodyHtml,
+        `</section>`,
+      ].join("\n")
+    })
+    .join("\n")
+}
+
+function serializeForScript(value: unknown) {
+  return JSON.stringify(value).replace(/</g, "\\u003c")
+}
+
+function snapshotTemplate(input: { document: PlanDocument; liveUrl?: string }) {
+  const summaryTable = renderSummaryTable(input.document.summaryRows)
+  const sectionHtml = renderSnapshotSections(input.document.sections)
