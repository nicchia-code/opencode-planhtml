@@ -0,0 +1,899 @@
+import { Button } from "@opencode-ai/ui/button"
+import { Spinner } from "@opencode-ai/ui/spinner"
+import { showToast } from "@opencode-ai/ui/toast"
+import { useSearchParams, useParams } from "@solidjs/router"
+import { createEffect, createMemo, createResource, createSignal, For, Match, onCleanup, onMount, Show, Switch, type Accessor, type JSX } from "solid-js"
+
+import { createPlanCommentSession, type PlanComment } from "@/context/plan-comments"
+import type { PlanCommentAnchor } from "@/context/plan-comments"
+import { useSDK } from "@/context/sdk"
+import { decode64 } from "@/utils/base64"
+import type {
+  PlanUserDocument,
+  PlanUserFieldRow,
+  PlanUserFieldTableNode,
+  PlanUserHeadingNode,
+  PlanUserListNode,
+  PlanUserNode,
+  PlanUserNoteNode,
+  PlanUserParagraphNode,
+  PlanUserToggleNode,
+} from "./session-plan-types"
+
+type PlanDocumentResponse = {
+  document: PlanUserDocument
+  markdown: string
+  sourcePath: string
+}
+
+type TextRangeAnchor = Extract<PlanCommentAnchor, { kind: "text-range" }>
+type ReviewFieldLabel = "what" | "why" | "files/tests"
+type InlinePieceKind = "text" | "strong" | "code"
+
+type InlinePiece = {
+  kind: InlinePieceKind
+  text: string
+}
+
+const REVIEW_BACKGROUND = "#fbfbfa"
+
+const REVIEW_THEME_STYLE: JSX.CSSProperties = {
+  "color-scheme": "light",
+  "font-family": 'ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif',
+  "--background-base": REVIEW_BACKGROUND,
+  "--background-weak": "#f7f6f3",
+  "--background-strong": "#ffffff",
+  "--background-stronger": "#ffffff",
+  "--surface-base": "rgba(55, 53, 47, 0.04)",
+  "--surface-base-hover": "rgba(55, 53, 47, 0.08)",
+  "--surface-base-active": "rgba(55, 53, 47, 0.12)",
+  "--surface-raised-base": "rgba(255, 255, 255, 0.92)",
+  "--surface-raised-strong": "#ffffff",
+  "--surface-raised-stronger": "#ffffff",
+  "--surface-strong": "#ffffff",
+  "--input-base": "#ffffff",
+  "--input-hover": "#fffdfb",
+  "--input-active": "#ffffff",
+  "--input-focus": "#ffffff",
+  "--text-base": "#4b4b47",
+  "--text-weak": "#787774",
+  "--text-weaker": "#9b9a97",
+  "--text-strong": "#2f3437",
+  "--text-interactive-base": "#2f76d2",
+  "--button-primary-base": "#2f3437",
+  "--button-secondary-base": "#ffffff",
+  "--button-secondary-hover": "#f7f6f3",
+  "--button-ghost-hover": "rgba(55, 53, 47, 0.05)",
+  "--button-ghost-hover2": "rgba(55, 53, 47, 0.08)",
+  "--border-base": "rgba(55, 53, 47, 0.16)",
+  "--border-weak-base": "rgba(55, 53, 47, 0.09)",
+  "--border-weaker-base": "rgba(55, 53, 47, 0.06)",
+  "--border-strong-base": "rgba(55, 53, 47, 0.22)",
+  "--border-selected": "rgba(47, 118, 210, 0.45)",
+  "--border-strong-selected": "rgba(47, 118, 210, 0.18)",
+  "--icon-base": "#8f8b86",
+  "--icon-hover": "#5f5c58",
+  "--icon-active": "#2f3437",
+  "--icon-selected": "#2f3437",
+  "--icon-invert-base": "#ffffff",
+}
+
+type PlanDocumentViewProps = {
+  document: PlanUserDocument
+  comments: Accessor<PlanComment[]>
+  onCommentNode?: (nodeID: string) => void
+}
+
+export function highlightText(text: string, comments: PlanComment[]) {
+  const highlights = getHighlightRanges(text, comments)
+
+  if (!highlights.length) return [{ type: "text" as const, value: text }]
+  const parts: Array<{ type: "text" | "mark"; value: string }> = []
+  let cursor = 0
+  for (const highlight of highlights) {
+    if (highlight.start < cursor) continue
+    if (highlight.start > cursor) {
+      parts.push({ type: "text", value: text.slice(cursor, highlight.start) })
+    }
+    parts.push({ type: "mark", value: text.slice(highlight.start, highlight.end) })
+    cursor = highlight.end
+  }
+  if (cursor < text.length) {
+    parts.push({ type: "text", value: text.slice(cursor) })
+  }
+  return parts
+}
+
+function getHighlightRanges(text: string, comments: PlanComment[]) {
+  return comments
+    .map((comment) => {
+      if (comment.anchor.kind !== "text-range" || !comment.anchor.quote) return null
+      const match = resolveTextRange(text, comment.anchor)
+      if (!match) return null
+      return {
+        start: match.start,
+        end: match.end,
+      }
+    })
+    .filter((item): item is { start: number; end: number } => Boolean(item))
+    .sort((a, b) => a.start - b.start)
+}
+
+function parseInlinePieces(text: string) {
+  const pieces: InlinePiece[] = []
+  const pattern = /(\*\*([^*]+)\*\*)|`([^`]+)`/g
+  let lastIndex = 0
+  let match: RegExpExecArray | null
+
+  while ((match = pattern.exec(text))) {
+    if (match.index > lastIndex) {
+      pieces.push({ kind: "text", text: text.slice(lastIndex, match.index) })
+    }
+
+    if (match[2]) {
+      pieces.push({ kind: "strong", text: match[2] })
+    } else if (match[3]) {
+      pieces.push({ kind: "code", text: match[3] })
+    }
+
+    lastIndex = match.index + match[0].length
+  }
+
+  if (lastIndex < text.length) {
+    pieces.push({ kind: "text", text: text.slice(lastIndex) })
+  }
+
+  return pieces.length ? pieces : [{ kind: "text", text }]
+}
+
+function visibleInlineText(text: string) {
+  return parseInlinePieces(text)
+    .map((piece) => piece.text)
+    .join("")
+}
+
+function renderInlinePiece(kind: InlinePieceKind, text: string) {
+  if (kind === "strong") return <strong class="font-semibold text-[#2f3437]">{text}</strong>
+  if (kind === "code") return <code class="rounded bg-[rgba(55,53,47,0.08)] px-1 py-0.5 text-[0.95em] text-[#1f2937]">{text}</code>
+  return text
+}
+
+function TextWithHighlights(props: { text: string; comments: PlanComment[] }) {
+  const pieces = createMemo(() => parseInlinePieces(props.text))
+  const highlights = createMemo(() => getHighlightRanges(visibleInlineText(props.text), props.comments))
+  return (
+    <>
+      <For each={splitInlinePiecesByHighlights(pieces(), highlights())}>
+        {(part) => {
+          const content = renderInlinePiece(part.kind, part.text)
+          return part.highlight ? <mark class="rounded-[4px] bg-[#fff1c2] px-0.5 text-current shadow-[inset_0_-1px_0_rgba(202,138,4,0.12)]">{content}</mark> : content
+        }}
+      </For>
+    </>
+  )
+}
+
+function splitInlinePiecesByHighlights(pieces: InlinePiece[], highlights: Array<{ start: number; end: number }>) {
+  const out: Array<InlinePiece & { highlight: boolean }> = []
+  let offset = 0
+
+  for (const piece of pieces) {
+    let cursor = 0
+    const pieceStart = offset
+    const pieceEnd = offset + piece.text.length
+
+    for (const highlight of highlights) {
+      if (highlight.end <= pieceStart || highlight.start >= pieceEnd) continue
+      const localStart = Math.max(0, highlight.start - pieceStart)
+      const localEnd = Math.min(piece.text.length, highlight.end - pieceStart)
+      if (localStart > cursor) {
+        out.push({ ...piece, text: piece.text.slice(cursor, localStart), highlight: false })
+      }
+      if (localEnd > localStart) {
+        out.push({ ...piece, text: piece.text.slice(localStart, localEnd), highlight: true })
+      }
+      cursor = Math.max(cursor, localEnd)
+    }
+
+    if (cursor < piece.text.length) {
+      out.push({ ...piece, text: piece.text.slice(cursor), highlight: false })
+    }
+
+    offset += piece.text.length
+  }
+
+  return out.filter((piece) => piece.text.length > 0)
+}
+
+function parseReviewField(text: string) {
+  const match = text.match(/^(What|Why|Files\/Tests|Files|Tests):\s*(.+)$/i)
+  if (!match) return null
+  const rawLabel = match[1].toLowerCase()
+  const label: ReviewFieldLabel = rawLabel === "files" || rawLabel === "tests" ? "files/tests" : (rawLabel as ReviewFieldLabel)
+  return {
+    label,
+    value: match[2].trim(),
+  }
+}
+
+function isHiddenReviewNode(node: PlanUserNode) {
+  if (node.kind === "heading") {
+    return node.text.trim().toLowerCase() === "actions"
+  }
+  if (node.kind === "paragraph") {
+    return ["actions"].includes(visibleInlineText(node.text).trim().toLowerCase())
+  }
+  return false
+}
+
+function groupReviewNodes(nodes: PlanUserNode[]) {
+  const groups: Array<{ kind: "node"; node: PlanUserNode } | { kind: "fields"; nodes: PlanUserParagraphNode[] }> = []
+  let index = 0
+  let hiddenSectionLevel: number | null = null
+
+  while (index < nodes.length) {
+    const node = nodes[index]
+    if (!node) {
+      index += 1
+      continue
+    }
+
+    if (hiddenSectionLevel !== null) {
+      if (node.kind === "heading" && node.level <= hiddenSectionLevel) {
+        hiddenSectionLevel = null
+      } else {
+        index += 1
+        continue
+      }
+    }
+
+    if (node.kind === "heading" && node.text.trim().toLowerCase() === "internal plan") {
+      hiddenSectionLevel = node.level
+      index += 1
+      continue
+    }
+
+    if (isHiddenReviewNode(node)) {
+      index += 1
+      continue
+    }
+
+    if (node.kind === "paragraph" && parseReviewField(node.text)) {
+      const fieldNodes: PlanUserParagraphNode[] = []
+      let cursor = index
+      while (cursor < nodes.length) {
+        const candidate = nodes[cursor]
+        if (!candidate || candidate.kind !== "paragraph" || !parseReviewField(candidate.text)) break
+        fieldNodes.push(candidate)
+        cursor += 1
+      }
+      groups.push({ kind: "fields", nodes: fieldNodes })
+      index = cursor
+      continue
+    }
+
+    groups.push({ kind: "node", node })
+    index += 1
+  }
+
+  return groups
+}
