+function groupReviewNodes(nodes: PlanUserNode[]) {
+  const groups: Array<{ kind: "node"; node: PlanUserNode } | { kind: "fields"; nodes: PlanUserParagraphNode[] }> = []
+  let index = 0
+  let hiddenSectionLevel: number | null = null
+
+  while (index < nodes.length) {
+    const node = nodes[index]
+    if (!node) {
+      index += 1
+      continue
+    }
+
+    if (hiddenSectionLevel !== null) {
+      if (node.kind === "heading" && node.level <= hiddenSectionLevel) {
+        hiddenSectionLevel = null
+      } else {
+        index += 1
+        continue
+      }
+    }
+
+    if (node.kind === "heading" && node.text.trim().toLowerCase() === "internal plan") {
+      hiddenSectionLevel = node.level
+      index += 1
+      continue
+    }
+
+    if (isHiddenReviewNode(node)) {
+      index += 1
+      continue
+    }
+
+    if (node.kind === "paragraph" && parseReviewField(node.text)) {
+      const fieldNodes: PlanUserParagraphNode[] = []
+      let cursor = index
+      while (cursor < nodes.length) {
+        const candidate = nodes[cursor]
+        if (!candidate || candidate.kind !== "paragraph" || !parseReviewField(candidate.text)) break
+        fieldNodes.push(candidate)
+        cursor += 1
+      }
+      groups.push({ kind: "fields", nodes: fieldNodes })
+      index = cursor
+      continue
+    }
