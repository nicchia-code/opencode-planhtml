+  test("rejects stale plan revisions", async () => {
+    await using tmp = await tmpdir({ git: true })
+    await Instance.provide({
+      directory: tmp.path,
+      fn: async () => {
+        const session = await Session.create({})
+        await SessionPlanHtml.renderPlanArtifacts({ session, markdown: SAMPLE_PLAN, autoOpen: false })
