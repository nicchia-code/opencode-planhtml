+        <aside class="sticky top-8 w-full max-w-[360px] shrink-0 self-start space-y-4">
+          <section class="rounded-[24px] border border-[rgba(55,53,47,0.08)] bg-white px-5 py-5 shadow-[0_1px_2px_rgba(15,23,42,0.04)]">
