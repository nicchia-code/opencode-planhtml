diff --git a/packages/app/src/context/plan-comments.test.ts b/packages/app/src/context/plan-comments.test.ts
new file mode 100644
index 000000000..632aee61b
--- /dev/null
+++ b/packages/app/src/context/plan-comments.test.ts
@@ -0,0 +1,49 @@
+import { describe, expect, test } from "bun:test"
+import { createRoot } from "solid-js"
+
+import type { PlanCommentAnchor } from "./plan-comments"
+import { createPlanCommentSessionForTest } from "./plan-comments"
+
+function textRange(nodeID: string, quote: string): PlanCommentAnchor {
+  return {
+    kind: "text-range",
+    nodeID,
+    quote,
+  }
+}
+
+describe("plan comments session", () => {
+  test("adds comments and keeps them sorted by time", () => {
+    createRoot((dispose) => {
+      const session = createPlanCommentSessionForTest()
+
+      const first = session.add({ anchor: textRange("node-a", "first"), comment: "First" })
+      const second = session.add({ anchor: textRange("node-b", "second"), comment: "Second" })
+
+      expect(session.all().map((item) => item.id)).toEqual([first.id, second.id])
+      expect(session.byNode("node-a").map((item) => item.comment)).toEqual(["First"])
+      dispose()
+    })
+  })
+
+  test("replace swaps comments and clears focus state", () => {
+    createRoot((dispose) => {
+      const session = createPlanCommentSessionForTest()
+      const draft = session.add({ anchor: textRange("node-a", "quote"), comment: "Draft" })
+      session.setFocus(draft.id)
+
+      session.replace([
+        {
+          id: "persisted",
+          time: 10,
+          comment: "Persisted",
+          anchor: textRange("node-b", "persisted quote"),
+        },
+      ])
+
+      expect(session.all().map((item) => item.id)).toEqual(["persisted"])
+      expect(session.focus()).toBeNull()
+      dispose()
+    })
+  })
+})

diff --git a/packages/app/src/context/plan-comments.ts b/packages/app/src/context/plan-comments.ts
new file mode 100644
index 000000000..59d1793e5
--- /dev/null
+++ b/packages/app/src/context/plan-comments.ts
@@ -0,0 +1,116 @@
+import { createStore } from "solid-js/store"
+import { uuid } from "@/utils/uuid"
+
+export type PlanCommentAnchor =
+  | {
+      kind: "node"
+      nodeID: string
+    }
+  | {
+      kind: "text-range"
+      nodeID: string
+      quote: string
+      prefix?: string
+      suffix?: string
+      start?: number
+      end?: number
+    }
+
+export type PlanComment = {
+  id: string
+  time: number
+  comment: string
+  anchor: PlanCommentAnchor
+}
+
+type Store = {
+  comments: PlanComment[]
+  focus: string | null
+}
+
+function sortComments(comments: PlanComment[]) {
+  return comments.slice().sort((a, b) => a.time - b.time)
+}
+
+function normalize(comments: PlanComment[]) {
+  return sortComments(
+    comments.map((comment) => ({
+      ...comment,
+      anchor: { ...comment.anchor },
+    })),
+  )
+}
+
+function readPersisted(storageKey?: string) {
+  if (!storageKey || typeof localStorage === "undefined") return [] as PlanComment[]
+  try {
+    const raw = localStorage.getItem(storageKey)
+    if (!raw) return []
+    return normalize(JSON.parse(raw))
+  } catch {
+    return []
+  }
+}
+
+export function createPlanCommentSession(storageKey?: string, initial: PlanComment[] = []) {
+  const [store, setStore] = createStore<Store>({
+    comments: storageKey ? readPersisted(storageKey) : normalize(initial),
+    focus: null,
+  })
+
+  const persist = () => {
+    if (!storageKey || typeof localStorage === "undefined") return
+    localStorage.setItem(storageKey, JSON.stringify(store.comments))
+  }
+
+  return {
+    all: () => store.comments,
+    byNode(nodeID: string) {
+      return store.comments.filter((comment) => comment.anchor.nodeID === nodeID)
+    },
+    add(input: { anchor: PlanCommentAnchor; comment: string }) {
+      const next: PlanComment = {
+        id: uuid(),
+        time: Date.now(),
+        anchor: { ...input.anchor },
+        comment: input.comment,
+      }
+      setStore("comments", (items) => sortComments([...(items ?? []), next]))
+      setStore("focus", next.id)
+      persist()
+      return next
+    },
+    update(id: string, comment: string) {
+      setStore("comments", (items) =>
+        (items ?? []).map((item) => {
+          if (item.id !== id) return item
+          return { ...item, comment }
+        }),
+      )
+      persist()
+    },
+    remove(id: string) {
+      setStore("comments", (items) => (items ?? []).filter((item) => item.id !== id))
+      setStore("focus", (current) => (current === id ? null : current))
+      persist()
+    },
+    replace(comments: PlanComment[]) {
+      setStore("comments", normalize(comments))
+      setStore("focus", null)
+      persist()
+    },
+    clear() {
+      setStore("comments", [])
+      setStore("focus", null)
+      persist()
+    },
+    focus: () => store.focus,
+    setFocus(id: string | null) {
+      setStore("focus", id)
+    },
+  }
+}
+
+export function createPlanCommentSessionForTest(initial: PlanComment[] = []) {
+  return createPlanCommentSession(undefined, initial)
+}

