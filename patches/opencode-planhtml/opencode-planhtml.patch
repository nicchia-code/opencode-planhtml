+import { randomBytes } from "node:crypto"
+import { Hono } from "hono"
+
+import { Instance } from "@/project/instance"
+import { InstanceBootstrap } from "@/project/bootstrap"
+import { setPlanServer } from "./plan-control"
+import { SessionPlanRoutes } from "../server/routes/session-plan"
+
+let server: ReturnType<typeof Bun.serve> | undefined
+let token = ""
+let directory = ""
+
+function nextToken() {
+  return randomBytes(24).toString("hex")
+}
+
+function appForDirectory(targetDirectory: string, currentToken: string) {
+  const routes = new Hono().route("/session", SessionPlanRoutes())
+  const app = new Hono()
+
+  app.use("*", async (c, next) => {
+    const value = c.req.query("token") || c.req.header("x-opencode-plan-token")
+    if (value !== currentToken) {
+      return c.text("Unauthorized", 401)
+    }
+    await next()
+  })
+
+  app.all("*", async (c) => {
+    return Instance.provide({
+      directory: targetDirectory,
+      init: InstanceBootstrap,
+      fn: () => routes.fetch(c.req.raw, c.env),
+    })
+  })
+
+  return app
+}
+
+export const PlanServer = {
+  ensure(input: { directory: string }) {
+    if (server && directory === input.directory) {
+      return {
+        url: server.url.toString(),
+        token,
+      }
+    }
+
+    if (server) {
+      server.stop(true)
+      server = undefined
+    }
+
+    directory = input.directory
+    token = nextToken()
+    const app = appForDirectory(directory, token)
+    server = Bun.serve({
+      hostname: "127.0.0.1",
+      port: 0,
+      idleTimeout: 0,
+      fetch: app.fetch,
+    })
+    setPlanServer({ url: server.url.toString(), token })
+
+    return {
+      url: server.url.toString(),
+      token,
+    }
+  },
