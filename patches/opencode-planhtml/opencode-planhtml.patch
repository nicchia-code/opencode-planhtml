+      credentials: "include",
+      ...init,
+      headers: {
+        ...(init?.headers ?? {}),
+        ...(init?.body ? { "content-type": "application/json" } : {}),
+      },
+    })
+    if (!res.ok) {
+      const payload = await res.json().catch(() => ({}))
