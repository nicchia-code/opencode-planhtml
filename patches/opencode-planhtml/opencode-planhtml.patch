+export function highlightText(text: string, comments: PlanComment[]) {
+  const highlights = getHighlightRanges(text, comments)
+
+  if (!highlights.length) return [{ type: "text" as const, value: text }]
+  const parts: Array<{ type: "text" | "mark"; value: string }> = []
+  let cursor = 0
+  for (const highlight of highlights) {
+    if (highlight.start < cursor) continue
+    if (highlight.start > cursor) {
+      parts.push({ type: "text", value: text.slice(cursor, highlight.start) })
+    }
+    parts.push({ type: "mark", value: text.slice(highlight.start, highlight.end) })
+    cursor = highlight.end
+  }
+  if (cursor < text.length) {
+    parts.push({ type: "text", value: text.slice(cursor) })
+  }
+  return parts
+}
+
+function getHighlightRanges(text: string, comments: PlanComment[]) {
+  return comments
+    .map((comment) => {
+      if (comment.anchor.kind !== "text-range" || !comment.anchor.quote) return null
+      const match = resolveTextRange(text, comment.anchor)
+      if (!match) return null
+      return {
+        start: match.start,
+        end: match.end,
+      }
+    })
+    .filter((item): item is { start: number; end: number } => Boolean(item))
+    .sort((a, b) => a.start - b.start)
+}
+
+function parseInlinePieces(text: string) {
+  const pieces: InlinePiece[] = []
+  const pattern = /(\*\*([^*]+)\*\*)|`([^`]+)`/g
+  let lastIndex = 0
+  let match: RegExpExecArray | null
+
+  while ((match = pattern.exec(text))) {
+    if (match.index > lastIndex) {
+      pieces.push({ kind: "text", text: text.slice(lastIndex, match.index) })
+    }
+
+    if (match[2]) {
+      pieces.push({ kind: "strong", text: match[2] })
+    } else if (match[3]) {
+      pieces.push({ kind: "code", text: match[3] })
+    }
+
+    lastIndex = match.index + match[0].length
+  }
+
+  if (lastIndex < text.length) {
+    pieces.push({ kind: "text", text: text.slice(lastIndex) })
+  }
+
+  return pieces.length ? pieces : [{ kind: "text", text }]
+}
+
+function visibleInlineText(text: string) {
+  return parseInlinePieces(text)
+    .map((piece) => piece.text)
+    .join("")
+}
+
+function renderInlinePiece(kind: InlinePieceKind, text: string) {
+  if (kind === "strong") return <strong class="font-semibold text-[#2f3437]">{text}</strong>
+  if (kind === "code") return <code class="rounded bg-[rgba(55,53,47,0.08)] px-1 py-0.5 text-[0.95em] text-[#1f2937]">{text}</code>
+  return text
+}
+
+function TextWithHighlights(props: { text: string; comments: PlanComment[] }) {
+  const pieces = createMemo(() => parseInlinePieces(props.text))
+  const highlights = createMemo(() => getHighlightRanges(visibleInlineText(props.text), props.comments))
+  return (
+    <>
+      <For each={splitInlinePiecesByHighlights(pieces(), highlights())}>
+        {(part) => {
+          const content = renderInlinePiece(part.kind, part.text)
+          return part.highlight ? <mark class="rounded-[4px] bg-[#fff1c2] px-0.5 text-current shadow-[inset_0_-1px_0_rgba(202,138,4,0.12)]">{content}</mark> : content
+        }}
+      </For>
+    </>
+  )
+}
+
+function splitInlinePiecesByHighlights(pieces: InlinePiece[], highlights: Array<{ start: number; end: number }>) {
+  const out: Array<InlinePiece & { highlight: boolean }> = []
+  let offset = 0
+
+  for (const piece of pieces) {
+    let cursor = 0
+    const pieceStart = offset
+    const pieceEnd = offset + piece.text.length
+
+    for (const highlight of highlights) {
+      if (highlight.end <= pieceStart || highlight.start >= pieceEnd) continue
+      const localStart = Math.max(0, highlight.start - pieceStart)
+      const localEnd = Math.min(piece.text.length, highlight.end - pieceStart)
+      if (localStart > cursor) {
+        out.push({ ...piece, text: piece.text.slice(cursor, localStart), highlight: false })
+      }
+      if (localEnd > localStart) {
+        out.push({ ...piece, text: piece.text.slice(localStart, localEnd), highlight: true })
+      }
+      cursor = Math.max(cursor, localEnd)
+    }
+
+    if (cursor < piece.text.length) {
+      out.push({ ...piece, text: piece.text.slice(cursor), highlight: false })
+    }
+
+    offset += piece.text.length
+  }
+
+  return out.filter((piece) => piece.text.length > 0)
+}
+
+function parseReviewField(text: string) {
+  const match = text.match(/^(What|Why|Files\/Tests|Files|Tests):\s*(.+)$/i)
+  if (!match) return null
+  const rawLabel = match[1].toLowerCase()
+  const label: ReviewFieldLabel = rawLabel === "files" || rawLabel === "tests" ? "files/tests" : (rawLabel as ReviewFieldLabel)
+  return {
+    label,
+    value: match[2].trim(),
+  }
