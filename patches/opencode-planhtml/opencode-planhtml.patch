diff --git a/packages/opencode/src/session/plan-action.ts b/packages/opencode/src/session/plan-action.ts
new file mode 100644
index 000000000..1a5c944cf
--- /dev/null
+++ b/packages/opencode/src/session/plan-action.ts
@@ -0,0 +1,363 @@
+import fs from "node:fs/promises"
+import path from "node:path"
+import { setTimeout as sleep } from "node:timers/promises"
+import z from "zod"
+
+import { Log } from "@/util/log"
+import { Session } from "./index"
+import { Question } from "../question"
+import { SessionPrompt } from "./prompt"
+import { SessionStatus } from "./status"
+import { MessageV2 } from "./message-v2"
+import { MessageID, PartID, type SessionID } from "./schema"
+import { Provider } from "../provider/provider"
+import { Instance } from "../project/instance"
+import * as SessionPlanHtml from "./plan-html"
+import * as SessionPlanUser from "./plan-user"
+
+const log = Log.create({ service: "session.plan-action" })
+
+const pendingReplans = new Map<SessionID, string>()
+
+export class StalePlanRevisionError extends Error {
+  constructor(
+    readonly currentPlanRevisionID: string,
+    readonly requestedPlanRevisionID: string,
+  ) {
+    super("The current plan revision does not match the requested revision")
+  }
+}
+
+export class PlanNotReadyError extends Error {
+  constructor() {
+    super("The plan is not ready to proceed yet")
+  }
+}
+
+export const LegacyPlanComment = z.object({
+  sectionID: z.string(),
+  title: z.string(),
+  note: z.string(),
+})
+
+export const PlanCommentAnchor = z.discriminatedUnion("kind", [
+  z.object({
+    kind: z.literal("node"),
+    nodeID: z.string(),
+  }),
+  z.object({
+    kind: z.literal("text-range"),
+    nodeID: z.string(),
+    quote: z.string(),
+    prefix: z.string().optional(),
+    suffix: z.string().optional(),
+    start: z.number().optional(),
+    end: z.number().optional(),
+  }),
+])
+
+export const PlanComment = z.object({
+  anchor: PlanCommentAnchor,
+  note: z.string(),
+})
+
+export const ReplanInput = z.object({
+  planRevisionID: z.string(),
+  comments: z.array(z.union([LegacyPlanComment, PlanComment])).min(1),
+})
+
+export const ProceedInput = z.object({
+  planRevisionID: z.string(),
+})
+
+async function getLastModel(sessionID: SessionID) {
+  for await (const item of MessageV2.stream(sessionID)) {
+    if (item.info.role === "user" && item.info.model) return item.info.model
+  }
+  return Provider.defaultModel()
+}
+
+function consumePendingReplanIfRevisionChanged(sessionID: SessionID, currentPlanRevisionID: string) {
+  const pendingRevisionID = pendingReplans.get(sessionID)
+  if (!pendingRevisionID) return false
+  if (pendingRevisionID === currentPlanRevisionID) return false
+  pendingReplans.delete(sessionID)
+  return true
+}
+
+export async function getCurrentPlan(sessionID: SessionID) {
+  const session = await Session.get(sessionID)
+  const sourcePath = Session.plan(session)
+  const markdown = await fs.readFile(sourcePath, "utf8")
+  const document = SessionPlanHtml.buildPlanDocument(markdown, sourcePath)
+  const userSourcePath = Session.planUser(session)
+  const shouldRefreshUserPlan = consumePendingReplanIfRevisionChanged(sessionID, document.planRevisionID)
+  let user:
+    | {
+        sourcePath: string
+        markdown: string
+        document: SessionPlanUser.PlanUserDocument
+      }
+    | undefined
+
+  if (!shouldRefreshUserPlan) {
+    try {
+      const userMarkdown = await fs.readFile(userSourcePath, "utf8")
+      user = {
+        sourcePath: userSourcePath,
+        markdown: userMarkdown,
+        document: SessionPlanUser.buildPlanUserDocument(userMarkdown, userSourcePath),
+      }
+    } catch (error) {
+      if ((error as NodeJS.ErrnoException | undefined)?.code !== "ENOENT") throw error
+    }
+  }
+
+  if (!user && SessionPlanHtml.isPlanReadyForOpen(markdown)) {
+    const userMarkdown = SessionPlanUser.deriveUserPlanMarkdown(markdown)
+    await fs.mkdir(path.dirname(userSourcePath), { recursive: true })
+    await fs.writeFile(userSourcePath, userMarkdown, "utf8")
+    user = {
+      sourcePath: userSourcePath,
+      markdown: userMarkdown,
+      document: SessionPlanUser.buildPlanUserDocument(userMarkdown, userSourcePath),
+    }
+  }
+
+  SessionPlanHtml.assertReadyPlanHasUserFacingPlan({
+    ready: SessionPlanHtml.isPlanReadyForOpen(markdown),
+    sessionID,
+    userMarkdown: user?.markdown,
+    userMarkdownPath: userSourcePath,
+  })
+
+  return { session, sourcePath, markdown, document, user }
+}
+
+async function waitForIdle(sessionID: SessionID, timeoutMs = 4000) {
+  const started = Date.now()
+  while (Date.now() - started < timeoutMs) {
+    const status = await SessionStatus.get(sessionID)
+    if (status.type === "idle") return
+    await sleep(50)
+  }
+}
+
+function normalizeComments(comments: Array<z.infer<typeof LegacyPlanComment> | z.infer<typeof PlanComment>>) {
+  return comments
+    .map((comment) => {
+      if ("sectionID" in comment) {
+        return {
+          kind: "legacy" as const,
+          sectionID: comment.sectionID,
+          title: comment.title.trim(),
+          note: comment.note.trim(),
+        }
+      }
+      return {
+        kind: "anchor" as const,
+        anchor: comment.anchor,
+        note: comment.note.trim(),
+      }
+    })
+    .filter((comment) => comment.note.length > 0)
+}
+
+function formatReplanPrompt(
+  input: Awaited<ReturnType<typeof getCurrentPlan>>,
+  comments: ReturnType<typeof normalizeComments>,
+) {
+  const bySection = new Map(input.document.sections.map((section) => [section.id, section]))
+  const userTargets = input.user ? new Map(SessionPlanUser.flattenPlanUserTargets(input.user.document).map((target) => [target.id, target])) : new Map()
+  const lines = [
+    "Revise the current internal plan and the current user-facing plan using the comments below.",
+    "",
+    "Both plans must remain fully self-contained.",
+    "Do not refer to a previous plan, an earlier version, or unchanged sections elsewhere.",
+    "Preserve the overall structure unless a requested change requires otherwise.",
+    "Keep untouched areas as-is when possible, but always rewrite both final plan files as complete standalone documents.",
+    "The internal plan must still follow:",
+    "# Goal",
+    "# Plan Rationale",
+    "# Actions",
+    "## Step N",
+    "What:",
+    "Why:",
+    "Files/Tests:",
+    "",
+    "",
+    "The user-facing plan must still follow:",
+    "# Goal",
+    "# Piano Razionale",
+    "plus structured headings, paragraphs, and special blocks like :::toggle[Title] ... ::: when they help readability.",
+    "",
+    "Requested revisions:",
+  ]
+
+  comments.forEach((comment, index) => {
+    lines.push(`${index + 1}. Requested change`)
+    if (comment.kind === "legacy") {
+      const section = bySection.get(comment.sectionID)
+      lines.push(`Internal plan section: ${comment.title}`)
+      if (section?.action) lines.push(`Current What: ${section.action}`)
+      if (section?.why) lines.push(`Current Why: ${section.why}`)
+      if (section?.filesTests) lines.push(`Current Files/Tests: ${section.filesTests}`)
+      lines.push(`Requested change: ${comment.note}`)
+      lines.push("")
+      return
+    }
+
+    const target = userTargets.get(comment.anchor.nodeID)
+    if (target) {
+      lines.push(`User plan node: ${target.kind}`)
+      lines.push(`Current text: ${target.text}`)
+    } else {
+      lines.push(`User plan node: ${comment.anchor.nodeID}`)
+    }
+    if (comment.anchor.kind === "text-range") {
+      lines.push(`Highlighted text: ${comment.anchor.quote}`)
+      if (comment.anchor.prefix) lines.push(`Left context: ${comment.anchor.prefix}`)
+      if (comment.anchor.suffix) lines.push(`Right context: ${comment.anchor.suffix}`)
+    }
+    lines.push(`Requested change: ${comment.note}`)
+    lines.push("")
+  })
+
+  return lines.join("\n").trim()
+}
+
+export async function findPendingBuildQuestion(sessionID: SessionID) {
+  const pending = await Question.list()
+  return pending.find((request) => {
+    if (request.sessionID !== sessionID) return false
+    const question = request.questions[0]
+    if (!question) return false
+    if (question.header !== "Build Agent") return false
+    const labels = question.options.map((option) => option.label)
+    return labels.includes("Yes") && labels.includes("No")
+  })
+}
+
+export async function assertCurrentPlanRevision(sessionID: SessionID, planRevisionID: string) {
+  const current = await getCurrentPlan(sessionID)
+  const currentRevisionID = current.user?.document.planRevisionID ?? current.document.planRevisionID
+  if (currentRevisionID !== planRevisionID) {
+    throw new StalePlanRevisionError(currentRevisionID, planRevisionID)
+  }
+  return current
+}
+
+export async function approvePlan(sessionID: SessionID) {
+  const session = await Session.get(sessionID)
+  const plan = path.relative(Instance.worktree, Session.plan(session))
+  const model = await getLastModel(sessionID)
+
+  const userMsg: MessageV2.User = {
+    id: MessageID.ascending(),
+    sessionID,
+    role: "user",
+    time: {
+      created: Date.now(),
+    },
+    agent: "build",
+    model,
+  }
+  await Session.updateMessage(userMsg)
+  await Session.updatePart({
+    id: PartID.ascending(),
+    messageID: userMsg.id,
+    sessionID,
+    type: "text",
+    text: `The plan at ${plan} has been approved, you can now edit files. Execute the plan`,
+    synthetic: true,
+  } satisfies MessageV2.TextPart)
+
+  return { plan }
+}
+
+export async function requestPlanRevision(sessionID: SessionID, input: z.input<typeof ReplanInput>) {
+  const parsed = ReplanInput.parse(input)
+  const current = await assertCurrentPlanRevision(sessionID, parsed.planRevisionID)
+  const comments = normalizeComments(parsed.comments)
+
+  if (!comments.length) {
+    throw new Error("At least one comment is required")
+  }
+
+  const knownSections = new Set(current.document.sections.map((section) => section.id))
+  const knownTargets = current.user ? new Set(SessionPlanUser.flattenPlanUserTargets(current.user.document).map((target) => target.id)) : new Set<string>()
+  for (const comment of comments) {
+    if (comment.kind === "legacy") {
+      if (!knownSections.has(comment.sectionID)) {
+        throw new Error(`Unknown plan section: ${comment.sectionID}`)
+      }
+      continue
+    }
+    if (current.user && !knownTargets.has(comment.anchor.nodeID)) {
+      throw new Error(`Unknown plan node: ${comment.anchor.nodeID}`)
+    }
+  }
+
+  const pending = await findPendingBuildQuestion(sessionID)
+  if (pending) {
+    await Question.reply({
+      requestID: pending.id,
+      answers: [["No"]],
+    })
+  }
+
+  const prompt = formatReplanPrompt(current, comments)
+  pendingReplans.set(sessionID, current.document.planRevisionID)
+  const startPrompt = Instance.bind(async () => {
+    await waitForIdle(sessionID)
+    const model = await getLastModel(sessionID)
+    await SessionPrompt.prompt({
+      sessionID,
+      agent: "plan",
+      model,
+      parts: [{ type: "text", text: prompt }],
+    })
+  })
+  void Promise.resolve()
+    .then(startPrompt)
+    .catch((error) => {
+      pendingReplans.delete(sessionID)
+      log.error("replan request failed", {
+        sessionID,
+        error: error instanceof Error ? error.message : String(error),
+      })
+    })
+
+  return {
+    accepted: true as const,
+    commentCount: comments.length,
+  }
+}
+
+export async function proceedPlan(sessionID: SessionID, input: z.input<typeof ProceedInput>) {
+  const parsed = ProceedInput.parse(input)
+  await assertCurrentPlanRevision(sessionID, parsed.planRevisionID)
+
+  const pending = await findPendingBuildQuestion(sessionID)
+  if (pending) {
+    await Question.reply({
+      requestID: pending.id,
+      answers: [["Yes"]],
+    })
+    return {
+      accepted: true as const,
+      source: "question" as const,
+    }
+  }
+
+  const status = await SessionStatus.get(sessionID)
+  if (status.type !== "idle") {
+    throw new PlanNotReadyError()
+  }
+
+  await approvePlan(sessionID)
+  return {
+    accepted: true as const,
+    source: "direct" as const,
+  }
+}

