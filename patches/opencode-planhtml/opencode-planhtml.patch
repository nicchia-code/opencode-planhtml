diff --git a/packages/opencode/src/session/plan-action.ts b/packages/opencode/src/session/plan-action.ts
new file mode 100644
index 000000000..5b096a34e
--- /dev/null
+++ b/packages/opencode/src/session/plan-action.ts
@@ -0,0 +1,242 @@
+import fs from "node:fs/promises"
+import path from "node:path"
+import { setTimeout as sleep } from "node:timers/promises"
+import z from "zod"
+
+import { Log } from "@/util/log"
+import { Session } from "./index"
+import { Question } from "../question"
+import { SessionPrompt } from "./prompt"
+import { SessionStatus } from "./status"
+import { MessageV2 } from "./message-v2"
+import { MessageID, PartID, type SessionID } from "./schema"
+import { Provider } from "../provider/provider"
+import { Instance } from "../project/instance"
+import * as SessionPlanHtml from "./plan-html"
+
+const log = Log.create({ service: "session.plan-action" })
+
+export class StalePlanRevisionError extends Error {
+  constructor(
+    readonly currentPlanRevisionID: string,
+    readonly requestedPlanRevisionID: string,
+  ) {
+    super("The current plan revision does not match the requested revision")
+  }
+}
+
+export class PlanNotReadyError extends Error {
+  constructor() {
+    super("The plan is not ready to proceed yet")
+  }
+}
+
+export const PlanComment = z.object({
+  sectionID: z.string(),
+  title: z.string(),
+  note: z.string(),
+})
+
+export const ReplanInput = z.object({
+  planRevisionID: z.string(),
+  comments: z.array(PlanComment).min(1),
+})
+
+export const ProceedInput = z.object({
+  planRevisionID: z.string(),
+})
+
+async function getLastModel(sessionID: SessionID) {
+  for await (const item of MessageV2.stream(sessionID)) {
+    if (item.info.role === "user" && item.info.model) return item.info.model
+  }
+  return Provider.defaultModel()
+}
+
+async function getCurrentPlan(sessionID: SessionID) {
+  const session = await Session.get(sessionID)
+  const sourcePath = Session.plan(session)
+  const markdown = await fs.readFile(sourcePath, "utf8")
+  const document = SessionPlanHtml.buildPlanDocument(markdown, sourcePath)
+  return { session, sourcePath, markdown, document }
+}
+
+async function waitForIdle(sessionID: SessionID, timeoutMs = 4000) {
+  const started = Date.now()
+  while (Date.now() - started < timeoutMs) {
+    const status = await SessionStatus.get(sessionID)
+    if (status.type === "idle") return
+    await sleep(50)
+  }
+}
+
+function normalizeComments(comments: z.infer<typeof PlanComment>[]) {
+  return comments
+    .map((comment) => ({
+      sectionID: comment.sectionID,
+      title: comment.title.trim(),
+      note: comment.note.trim(),
+    }))
+    .filter((comment) => comment.note.length > 0)
+}
+
+function formatReplanPrompt(
+  document: SessionPlanHtml.PlanDocument,
+  comments: Array<{ sectionID: string; title: string; note: string }>,
+) {
+  const bySection = new Map(document.sections.map((section) => [section.id, section]))
+  const lines = [
+    "Revise the current plan using the user comments below.",
+    "",
+    "Preserve the overall plan structure unless a requested change requires otherwise.",
+    "Keep untouched steps as-is when possible.",
+    "Return a complete updated plan that still follows:",
+    "# Goal",
+    "# Plan Rationale",
+    "# Actions",
+    "## Step N",
+    "What:",
+    "Why:",
+    "Files/Tests:",
+    "",
+    "Requested revisions:",
+  ]
+
+  comments.forEach((comment, index) => {
+    const section = bySection.get(comment.sectionID)
+    lines.push(`${index + 1}. ${comment.title}`)
+    if (section?.action) lines.push(`Current What: ${section.action}`)
+    if (section?.why) lines.push(`Current Why: ${section.why}`)
+    if (section?.filesTests) lines.push(`Current Files/Tests: ${section.filesTests}`)
+    lines.push(`Requested change: ${comment.note}`)
+    lines.push("")
+  })
+
+  return lines.join("\n").trim()
+}
+
+export async function findPendingBuildQuestion(sessionID: SessionID) {
+  const pending = await Question.list()
+  return pending.find((request) => {
+    if (request.sessionID !== sessionID) return false
+    const question = request.questions[0]
+    if (!question) return false
+    if (question.header !== "Build Agent") return false
+    const labels = question.options.map((option) => option.label)
+    return labels.includes("Yes") && labels.includes("No")
+  })
+}
+
+export async function assertCurrentPlanRevision(sessionID: SessionID, planRevisionID: string) {
+  const current = await getCurrentPlan(sessionID)
+  if (current.document.planRevisionID !== planRevisionID) {
+    throw new StalePlanRevisionError(current.document.planRevisionID, planRevisionID)
+  }
+  return current
+}
+
+export async function approvePlan(sessionID: SessionID) {
+  const session = await Session.get(sessionID)
+  const plan = path.relative(Instance.worktree, Session.plan(session))
+  const model = await getLastModel(sessionID)
+
+  const userMsg: MessageV2.User = {
+    id: MessageID.ascending(),
+    sessionID,
+    role: "user",
+    time: {
+      created: Date.now(),
+    },
+    agent: "build",
+    model,
+  }
+  await Session.updateMessage(userMsg)
+  await Session.updatePart({
+    id: PartID.ascending(),
+    messageID: userMsg.id,
+    sessionID,
+    type: "text",
+    text: `The plan at ${plan} has been approved, you can now edit files. Execute the plan`,
+    synthetic: true,
+  } satisfies MessageV2.TextPart)
+
+  return { plan }
+}
+
+export async function requestPlanRevision(sessionID: SessionID, input: z.input<typeof ReplanInput>) {
+  const parsed = ReplanInput.parse(input)
+  const current = await assertCurrentPlanRevision(sessionID, parsed.planRevisionID)
+  const comments = normalizeComments(parsed.comments)
+
+  if (!comments.length) {
+    throw new Error("At least one comment is required")
+  }
+
+  const knownSections = new Set(current.document.sections.map((section) => section.id))
+  for (const comment of comments) {
+    if (!knownSections.has(comment.sectionID)) {
+      throw new Error(`Unknown plan section: ${comment.sectionID}`)
+    }
+  }
+
+  const pending = await findPendingBuildQuestion(sessionID)
+  if (pending) {
+    await Question.reply({
+      requestID: pending.id,
+      answers: [["No"]],
+    })
+  }
+
+  const prompt = formatReplanPrompt(current.document, comments)
+  const startPrompt = Instance.bind(async () => {
+    await waitForIdle(sessionID)
+    const model = await getLastModel(sessionID)
+    await SessionPrompt.prompt({
+      sessionID,
+      agent: "plan",
+      model,
+      parts: [{ type: "text", text: prompt }],
+    })
+  })
+  void Promise.resolve()
+    .then(startPrompt)
+    .catch((error) => {
+      log.error("replan request failed", {
+        sessionID,
+        error: error instanceof Error ? error.message : String(error),
+      })
+    })
+
+  return {
+    accepted: true as const,
+    commentCount: comments.length,
+  }
+}
+
+export async function proceedPlan(sessionID: SessionID, input: z.input<typeof ProceedInput>) {
+  const parsed = ProceedInput.parse(input)
+  await assertCurrentPlanRevision(sessionID, parsed.planRevisionID)
+
+  const pending = await findPendingBuildQuestion(sessionID)
+  if (pending) {
+    await Question.reply({
+      requestID: pending.id,
+      answers: [["Yes"]],
+    })
+    return {
+      accepted: true as const,
+      source: "question" as const,
+    }
+  }
+
+  const status = await SessionStatus.get(sessionID)
+  if (status.type !== "idle") {
+    throw new PlanNotReadyError()
+  }
+
+  await approvePlan(sessionID)
+  return {
+    accepted: true as const,
+    source: "direct" as const,
+  }
+}

diff --git a/packages/opencode/src/session/plan-control.ts b/packages/opencode/src/session/plan-control.ts
