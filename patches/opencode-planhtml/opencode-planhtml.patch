+export function resolveSelectionAnchor(selection: Selection | null): PlanCommentAnchor | null {
+  if (!selection || selection.rangeCount === 0) return null
+  const range = selection.getRangeAt(0)
+  if (range.collapsed) return null
+  const startElement = getSelectableNodeElement(range.startContainer)
+  const endElement = getSelectableNodeElement(range.endContainer)
+  if (!startElement || !endElement || startElement !== endElement) return null
+  const nodeID = startElement.dataset.planNodeId
+  if (!nodeID) return null
+  const raw = range.toString()
+  const quote = raw.trim()
+  if (!quote) return null
+  const text = startElement.textContent ?? ""
+  const offsetRange = range.cloneRange()
+  offsetRange.selectNodeContents(startElement)
+  offsetRange.setEnd(range.startContainer, range.startOffset)
+  const baseStart = offsetRange.toString().length
+  const lead = raw.indexOf(quote)
+  const start = baseStart + Math.max(0, lead)
+  const end = start + quote.length
+  return {
+    kind: "text-range",
+    nodeID,
+    quote,
+    start,
+    end,
+    prefix: start > 0 ? text.slice(Math.max(0, start - 32), start) : undefined,
+    suffix: text.slice(end, Math.min(text.length, end + 32)) || undefined,
+  }
+}
+
+export function hasPlanRevisionUpdated(currentRevisionID?: string, pendingRevisionID?: string | null) {
+  return Boolean(currentRevisionID && pendingRevisionID && currentRevisionID !== pendingRevisionID)
+}
+
+function describeAnchor(anchor: PlanCommentAnchor) {
+  if (anchor.kind === "node") return `Node ${anchor.nodeID}`
+  return anchor.quote
+}
