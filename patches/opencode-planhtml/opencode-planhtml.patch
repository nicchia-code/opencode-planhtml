+      directory: tmp.path,
+      fn: async () => {
+        const session = await Session.create({})
+        const artifacts = await SessionPlanHtml.renderPlanArtifacts({
+          session,
+          markdown: SAMPLE_PLAN,
+          userMarkdown: SAMPLE_USER_PLAN,
+          autoOpen: false,
+        })
+
+        const page = await fetch(artifacts.liveUrl!, {
+          headers: {
+            cookie: "opencode-plan-token=stale-token",
+          },
+        })
+        const cookie = page.headers.get("set-cookie")
+        const cookieHeader = cookie?.split(";", 1)[0]
+        const html = await page.text()
+        const bundlePath = html.match(/src="([^"]*\/assets\/[^"]+\.js)"/)?.[1]
+
+        expect(page.status).toBe(200)
+        expect(cookie).toContain("opencode-plan-token=")
+        expect(cookieHeader).not.toBe("opencode-plan-token=stale-token")
+        expect(bundlePath).toBeTruthy()
+
+        const bundle = await fetch(new URL(bundlePath!, artifacts.liveUrl!), {
+          headers: { cookie: cookieHeader! },
+        })
+        expect(bundle.status).toBe(200)
+
+        await Session.remove(session.id)
+      },
+    })
+  })
+
+  test("throws when a user-facing plan cannot publish a live review url", async () => {
+    await using tmp = await tmpdir({ git: true })
+
+    await Instance.provide({
+      directory: tmp.path,
+      fn: async () => {
+        const ensure = spyOn(PlanServer, "ensure").mockImplementation(() => ({ url: "http://127.0.0.1:1", token: "plan-token" }))
+        const session = await Session.create({})
+
+        await expect(
+          SessionPlanHtml.renderPlanArtifacts({
+            session,
+            markdown: SAMPLE_PLAN,
+            userMarkdown: SAMPLE_USER_PLAN,
+            autoOpen: false,
+          }),
+        ).rejects.toThrow("plan live review URL unavailable")
+
+        ensure.mockRestore()
+        await Session.remove(session.id)
+      },
+    })
+  })
+})

