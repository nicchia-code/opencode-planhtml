+  const [busy, setBusy] = createSignal(false)
+  const [pendingRevisionID, setPendingRevisionID] = createSignal<string | null>(null)
+  const refreshingPlan = createMemo(() => Boolean(pendingRevisionID()))
+
+  const api = async <T,>(pathname: string, init?: RequestInit): Promise<T> => {
+    const url = new URL(pathname, window.location.origin)
+    url.searchParams.set("directory", directory())
+    const res = await fetch(url, {
+      credentials: "include",
+      ...init,
+      headers: {
+        ...(init?.headers ?? {}),
+        ...(init?.body ? { "content-type": "application/json" } : {}),
+      },
+    })
+    if (!res.ok) {
+      const payload = await res.json().catch(() => ({}))
+      throw new Error(payload.error || `request_failed_${res.status}`)
+    }
+    return res.json() as Promise<T>
+  }
+
+  const [plan, { refetch }] = createResource(
