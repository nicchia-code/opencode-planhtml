diff --git a/packages/opencode/src/server/routes/session-plan.ts b/packages/opencode/src/server/routes/session-plan.ts
new file mode 100644
index 000000000..2ff920b47
--- /dev/null
+++ b/packages/opencode/src/server/routes/session-plan.ts
@@ -0,0 +1,98 @@
+import fs from "node:fs/promises"
+import { Hono } from "hono"
+import { validator } from "hono-openapi"
+import z from "zod"
+
+import { SessionID } from "@/session/schema"
+import { Session } from "../../session"
+import * as SessionPlanAction from "../../session/plan-action"
+import * as SessionPlanHtml from "../../session/plan-html"
+import { lazy } from "../../util/lazy"
+
+const params = z.object({
+  sessionID: SessionID.zod,
+})
+
+export const SessionPlanRoutes = lazy(() =>
+  new Hono()
+    .get("/:sessionID/plan", validator("param", params), async (c) => {
+      const sessionID = c.req.valid("param").sessionID
+      const token = c.req.query("token") || c.req.header("x-opencode-plan-token") || undefined
+
+      try {
+        const session = await Session.get(sessionID)
+        const sourcePath = Session.plan(session)
+        const markdown = await fs.readFile(sourcePath, "utf8")
+        const document = SessionPlanHtml.buildPlanDocument(markdown, sourcePath)
+        const html = SessionPlanHtml.renderInteractivePlanHtml({
+          document,
+          sessionID,
+          replanUrl: `/session/${sessionID}/plan/replan`,
+          proceedUrl: `/session/${sessionID}/plan/proceed`,
+          token,
+        })
+
+        return new Response(html, {
+          headers: {
+            "content-type": "text/html; charset=utf-8",
+          },
+        })
+      } catch (error) {
+        if ((error as NodeJS.ErrnoException | undefined)?.code === "ENOENT") {
+          return c.json({ error: "plan_not_found" }, 404)
+        }
+        throw error
+      }
+    })
+    .post(
+      "/:sessionID/plan/replan",
+      validator("param", params),
+      validator("json", SessionPlanAction.ReplanInput),
+      async (c) => {
+        const sessionID = c.req.valid("param").sessionID
+
+        try {
+          const result = await SessionPlanAction.requestPlanRevision(sessionID, c.req.valid("json"))
+          return c.json(result)
+        } catch (error) {
+          if (error instanceof SessionPlanAction.StalePlanRevisionError) {
+            return c.json(
+              {
+                error: "stale_plan_revision",
+                currentPlanRevisionID: error.currentPlanRevisionID,
+              },
+              409,
+            )
+          }
+          throw error
+        }
+      },
+    )
+    .post(
+      "/:sessionID/plan/proceed",
+      validator("param", params),
+      validator("json", SessionPlanAction.ProceedInput),
+      async (c) => {
+        const sessionID = c.req.valid("param").sessionID
+
+        try {
+          const result = await SessionPlanAction.proceedPlan(sessionID, c.req.valid("json"))
+          return c.json(result)
+        } catch (error) {
+          if (error instanceof SessionPlanAction.StalePlanRevisionError) {
+            return c.json(
+              {
+                error: "stale_plan_revision",
+                currentPlanRevisionID: error.currentPlanRevisionID,
+              },
+              409,
+            )
+          }
+          if (error instanceof SessionPlanAction.PlanNotReadyError) {
+            return c.json({ error: "plan_not_ready" }, 409)
+          }
+          throw error
+        }
+      },
+    ),
+)

