+    "<!doctype html>",
+    '<html lang="en">',
+    "<head>",
+    '  <meta charset="utf-8">',
+    '  <meta name="viewport" content="width=device-width, initial-scale=1">',
+    `  <title>${escapeHtml(input.document.title)}</title>`,
+    "  <style>",
+    planStyles(),
+    "  </style>",
+    "</head>",
+    `<body data-session-id="${input.sessionID}" data-plan-revision-id="${input.document.planRevisionID}">`,
+    "  <main>",
+    "    <header>",
+    `      <p class="meta">Live plan review</p>`,
+    `      <h1>${renderInline(input.document.title)}</h1>`,
+    `      <p class="meta">Plan revision <code>${escapeHtml(input.document.planRevisionID.slice(0, 12))}</code> · Source <code>${escapeHtml(input.document.sourcePath)}</code></p>`,
+    input.document.leadHtml ? `      <div class="lead">${input.document.leadHtml}</div>` : "",
+    "    </header>",
+    renderSummaryTable(input.document.summaryRows),
+    sections,
+    '    <section class="actions" aria-label="Plan actions">',
+    '      <div class="actions-copy">',
+    '        <strong>Review the plan, leave notes where needed, then send one revision request.</strong>',
+    '        <span class="meta" data-plan-status>Ready to review.</span>',
+    '      </div>',
+    '      <div class="actions-controls">',
+    '        <button class="primary" type="button" data-action="replan">Propose Revised Plan</button>',
+    '        <button type="button" data-action="proceed">Proceed</button>',
+    '      </div>',
+    '    </section>',
+    "  </main>",
+    "  <script>",
+    `    const PLAN_PAGE = ${serializeForScript(state)};`,
+    `    const noteInputs = Array.from(document.querySelectorAll('[data-note-input]'));`,
+    `    const statusEl = document.querySelector('[data-plan-status]');`,
+    `    const replanButton = document.querySelector('[data-action="replan"]');`,
+    `    const proceedButton = document.querySelector('[data-action="proceed"]');`,
+    "    const readDraft = () => { try { return JSON.parse(localStorage.getItem(PLAN_PAGE.storageKey) || '{}'); } catch { return {}; } };",
+    "    const writeDraft = (value) => localStorage.setItem(PLAN_PAGE.storageKey, JSON.stringify(value));",
+    "    const setStatus = (message, error = false) => { if (!statusEl) return; statusEl.textContent = message; statusEl.classList.toggle('status-error', error); };",
+    "    const collectComments = () => noteInputs.map((input) => ({ sectionID: input.dataset.sectionId || '', title: input.dataset.sectionTitle || '', note: input.value.trim() })).filter((item) => item.note.length > 0);",
+    "    const syncDraft = () => { const next = Object.fromEntries(noteInputs.map((input) => [input.dataset.sectionId || '', input.value])); writeDraft(next); };",
+    "    const setBusy = (busy) => { if (replanButton) replanButton.disabled = busy; if (proceedButton) proceedButton.disabled = busy; };",
+    "    const headers = () => { const result = { 'content-type': 'application/json' }; if (PLAN_PAGE.token) result['x-opencode-plan-token'] = PLAN_PAGE.token; return result; };",
+    "    const send = async (url, body) => { const res = await fetch(url, { method: 'POST', headers: headers(), body: JSON.stringify(body) }); if (!res.ok) { const payload = await res.json().catch(() => ({})); throw new Error(payload.error || `request_failed_${res.status}`); } return res.json().catch(() => ({})); };",
+    "    const draft = readDraft();",
+    "    for (const input of noteInputs) { const key = input.dataset.sectionId || ''; input.value = typeof draft[key] === 'string' ? draft[key] : ''; input.addEventListener('input', syncDraft); }",
+    "    replanButton?.addEventListener('click', async () => { const comments = collectComments(); if (!comments.length) { setStatus('Add at least one note before requesting a revised plan.', true); return; } setBusy(true); setStatus('Sending revision request...'); try { await send(PLAN_PAGE.replanUrl, { planRevisionID: PLAN_PAGE.planRevisionID, comments }); localStorage.removeItem(PLAN_PAGE.storageKey); for (const input of noteInputs) input.value = ''; setStatus('Revision request sent. OpenCode is drafting a new plan.'); } catch (error) { setStatus(error instanceof Error ? error.message : String(error), true); } finally { setBusy(false); } });",
+    "    proceedButton?.addEventListener('click', async () => { setBusy(true); setStatus('Approving plan and switching to build...'); try { await send(PLAN_PAGE.proceedUrl, { planRevisionID: PLAN_PAGE.planRevisionID }); setStatus('Proceed sent. OpenCode is switching to build mode.'); } catch (error) { setStatus(error instanceof Error ? error.message : String(error), true); } finally { setBusy(false); } });",
+    "  </script>",
+    "</body>",
+    "</html>",
+  ].join("\n")
+}
+
+function isWslEnvironment(env = process.env): boolean {
+  return process.platform === "linux" && (release().includes("WSL") || Boolean(env["WSL_DISTRO_NAME"]))
+}
+
+export function hasTodoWriteCompletion(parts: MessageV2.Part[]): boolean {
+  return parts.some((part) => part.type === "tool" && part.tool === "todowrite" && part.state.status === "completed")
+}
+
+export function markdownFromParts(parts: MessageV2.Part[]): string {
+  return parts
+    .filter((part): part is MessageV2.TextPart => part.type === "text" && !part.synthetic && !part.ignored)
+    .map((part) => normalizePlanMarkdown(part.text))
+    .map((part) => part.trim())
+    .filter(Boolean)
+    .join("\n\n")
+    .trim()
+}
+
+export function selectPlanMarkdownForArtifacts(input: { assistantMarkdown?: string; persistedMarkdown?: string }) {
+  const assistantMarkdown = normalizePlanMarkdown(input.assistantMarkdown ?? "").trim()
+  const persistedMarkdown = normalizePlanMarkdown(input.persistedMarkdown ?? "").trim()
+
+  if (isPlanReadyForOpen(assistantMarkdown)) return assistantMarkdown
+  if (isPlanReadyForOpen(persistedMarkdown)) return persistedMarkdown
+  return assistantMarkdown || persistedMarkdown
+}
+
+export function isPlanReadyForOpen(markdown: string): boolean {
+  const normalized = normalizePlanMarkdown(markdown)
+  if (!normalized) return false
+
+  return /^#\s+Goal\b/im.test(normalized) && /^#\s+Actions\b/im.test(normalized) && /^##\s+(Step|Phase)\b/im.test(normalized)
+}
+
+function planHash(markdown: string): string {
+  return createHash("sha256").update(normalizePlanMarkdown(markdown)).digest("hex")
+}
+
+export function buildPlanDocument(markdown: string, sourcePath: string): PlanDocument {
+  const parsed = parseSections(markdown)
+  const commentable = new Set(stepSections(parsed.sections).map((section) => section.id))
+  const sections = parsed.sections
+    .filter((section) => !RENDER_OMITTED_TITLES.has(section.title.trim().toLowerCase()))
+    .map<PlanSection>((section) => {
+      const summary = summarizeSection(section)
+      return {
+        level: section.level,
+        title: section.title,
+        id: section.id,
+        body: section.body,
+        bodyHtml: renderMarkdownFragment(section.body),
+        action: extractLabeledValue(section.body, "What") ?? summary.action,
+        why: extractLabeledValue(section.body, "Why") ?? summary.why,
+        filesTests: extractLabeledValue(section.body, "Files/Tests"),
+        commentable: commentable.has(section.id),
+      }
+    })
+  const summaryRows = sections
+    .filter((section) => section.commentable)
+    .map((section) => ({
+      title: section.title,
+      id: section.id,
+      action: section.action ?? section.title,
+      why: section.why ?? "See step details",
+    }))
+
+  return {
+    title: parsed.title === "Plan" ? fallbackTitle(sourcePath) : parsed.title,
+    sourcePath,
+    generatedAt: new Date().toLocaleString(),
+    planRevisionID: planHash(markdown),
+    leadHtml: parsed.lead ? renderMarkdownFragment(parsed.lead) : "",
+    sections,
+    summaryRows,
+  }
+}
+
+export function shouldAttachPlanHtml(sessionID: SessionID, hash: string, ready: boolean): boolean {
+  if (!ready) return false
+  const previous = announcedPlanHashes.get(sessionID)
+  if (previous === hash) return false
+  announcedPlanHashes.set(sessionID, hash)
+  return true
+}
+
+export function renderPlanHtml(markdown: string, sourcePath: string, options?: { liveUrl?: string }): string {
+  const document = buildPlanDocument(markdown, sourcePath)
+  return snapshotTemplate({
+    document,
+    liveUrl: options?.liveUrl,
+  })
+}
+
+export function htmlAttachment(input: { htmlPath: string; messageID: MessageID; sessionID: SessionID }): MessageV2.FilePart {
+  return {
+    id: PartID.ascending(),
+    messageID: input.messageID,
+    sessionID: input.sessionID,
+    type: "file",
+    filename: path.basename(input.htmlPath),
+    mime: "text/html",
+    url: pathToFileURL(input.htmlPath).href,
+  }
+}
+
+async function openTarget(target: string): Promise<boolean> {
+  if (Flag.OPENCODE_DISABLE_PLAN_HTML_AUTO_OPEN || Boolean(process.env["CI"])) return false
+
+  if (isWslEnvironment()) {
+    if (which("wslview")) {
+      const result = await Process.run(["wslview", target], { nothrow: true })
+      if (result.code === 0) return true
+    }
+
+    if (!/^https?:\/\//.test(target) && which("wslpath") && which("powershell.exe")) {
+      const windowsPath = await Process.text(["wslpath", "-w", target], { nothrow: true })
+      const windowsTarget = windowsPath.text.trim()
+      if (windowsPath.code === 0 && windowsTarget) {
+        const command = `Start-Process -FilePath '${windowsTarget.replace(/'/g, "''")}'`
+        const result = await Process.run(["powershell.exe", "-NoProfile", "-Command", command], { nothrow: true })
+        if (result.code === 0) return true
+      }
+    }
+  }
+
+  try {
+    await open(target)
+    return true
+  } catch {
+    return false
+  }
+}
+
+async function writeHtml(htmlPath: string, html: string) {
+  await fs.mkdir(path.dirname(htmlPath), { recursive: true })
+  await fs.writeFile(htmlPath, html, "utf8")
+}
+
+async function ensurePlanLiveUrl(sessionID: SessionID) {
+  const existing = getPlanServerUrl(sessionID)
+  if (existing) return existing
+
+  const [{ Instance }, { PlanServer }] = await Promise.all([import("../project/instance"), import("./plan-server")])
+  PlanServer.ensure({ directory: getPlanServerDirectory() })
+  const liveUrl = getPlanServerUrl(sessionID)
+  if (liveUrl) return liveUrl
+
+  throw new Error(`plan live review URL unavailable for session ${sessionID}`)
+}
+
+export function assertReadyPlanHasUserFacingPlan(input: {
+  ready: boolean
+  sessionID: SessionID
+  userMarkdown?: string
+  userMarkdownPath: string
+}) {
+  if (!input.ready || input.userMarkdown) return
+  throw new MissingUserPlanError(input.sessionID, input.userMarkdownPath)
+}
+
+export async function renderPlanArtifacts(input: {
+  session: Session.Info
+  markdown: string
+  userMarkdown?: string
+  persistMarkdown?: boolean
+  autoOpen?: boolean
+}) {
+  const markdownPath = Session.plan(input.session)
+  const ready = isPlanReadyForOpen(input.markdown)
+  let liveUrl: string | undefined
+  const userMarkdownPath = Session.planUser(input.session)
+  const userHtmlPath = Session.planUserHtml(input.session)
+  const userDataPath = Session.planUserData(input.session)
+
+  if (input.persistMarkdown ?? true) {
+    await fs.mkdir(path.dirname(markdownPath), { recursive: true })
+    await fs.writeFile(markdownPath, input.markdown, "utf8")
+  }
+
+  let userMarkdown = input.userMarkdown
+  if (!userMarkdown) {
+    try {
+      userMarkdown = await fs.readFile(userMarkdownPath, "utf8")
+    } catch (error) {
+      if ((error as NodeJS.ErrnoException | undefined)?.code !== "ENOENT") throw error
+    }
+  }
+
+  if (!userMarkdown && ready) {
+    userMarkdown = SessionPlanUser.deriveUserPlanMarkdown(input.markdown)
+  }
+
+  if (userMarkdown && (input.persistMarkdown ?? true)) {
+    await fs.mkdir(path.dirname(userMarkdownPath), { recursive: true })
+    await fs.writeFile(userMarkdownPath, userMarkdown, "utf8")
+  }
+
+  assertReadyPlanHasUserFacingPlan({
+    ready,
+    sessionID: input.session.id,
+    userMarkdown,
+    userMarkdownPath,
+  })
+
+  let htmlPath = Session.planHtml(input.session)
+  let hash = planHash(input.markdown)
+  let html = renderPlanHtml(input.markdown, markdownPath, { liveUrl })
+  if (userMarkdown) {
+    liveUrl = ready ? await ensurePlanLiveUrl(input.session.id) : undefined
+    const document = SessionPlanUser.buildPlanUserDocument(userMarkdown, userMarkdownPath)
+    htmlPath = userHtmlPath
+    hash = document.planRevisionID
+    html = SessionPlanUser.renderPlanUserHtml(document)
+    await fs.writeFile(userDataPath, JSON.stringify({ document, markdown: userMarkdown }, null, 2), "utf8")
+  }
+  await writeHtml(htmlPath, html)
+
+  let opened = false
+  if (input.autoOpen !== false && ready && openedPlanHashes.get(input.session.id) !== hash && (!userMarkdown || liveUrl)) {
+    opened = await openTarget(userMarkdown ? liveUrl! : htmlPath)
+    if (opened) openedPlanHashes.set(input.session.id, hash)
+  }
+
+  return {
+    markdownPath,
+    userMarkdownPath,
+    htmlPath,
+    userDataPath,
+    liveUrl,
+    hash,
+    ready,
+    opened,
+  }
+}
+
+export async function renderExistingPlanArtifacts(input: { session: Session.Info; autoOpen?: boolean }) {
+  const markdownPath = Session.plan(input.session)
+  const markdown = await fs.readFile(markdownPath, "utf8")
+  let userMarkdown: string | undefined
+  try {
+    userMarkdown = await fs.readFile(Session.planUser(input.session), "utf8")
+  } catch (error) {
+    if ((error as NodeJS.ErrnoException | undefined)?.code !== "ENOENT") throw error
+  }
+  return renderPlanArtifacts({
+    session: input.session,
+    markdown,
+    userMarkdown,
+    persistMarkdown: false,
+    autoOpen: input.autoOpen,
+  })
+}

diff --git a/packages/opencode/src/session/plan-server.ts b/packages/opencode/src/session/plan-server.ts
new file mode 100644
index 000000000..82e97392d
--- /dev/null
+++ b/packages/opencode/src/session/plan-server.ts
@@ -0,0 +1,92 @@
+import { randomBytes } from "node:crypto"
+import { Hono } from "hono"
+import { getCookie } from "hono/cookie"
+
+import { Server } from "../server/server"
+import { setPlanServer } from "./plan-control"
+
+let server: ReturnType<typeof Bun.serve> | undefined
+let token = ""
+let directory = ""
+const COOKIE_NAME = "opencode-plan-token"
+
+function nextToken() {
+  return randomBytes(24).toString("hex")
+}
+
+function setPlanCookieHeader(headers: Headers, currentToken: string) {
+  headers.append("set-cookie", `${COOKIE_NAME}=${currentToken}; Path=/; HttpOnly; SameSite=Lax`)
+}
+
+function appForDirectory(targetDirectory: string, currentToken: string) {
+  const routes = Server.ControlPlaneRoutes({
+    cors: [`http://127.0.0.1`, `http://localhost`],
+  })
+  const app = new Hono()
+
+  app.all("*", async (c) => {
+    const cookie = getCookie(c, COOKIE_NAME)
+    const value = c.req.query("plan-token") || c.req.header("x-opencode-plan-token") || cookie
+    if (value !== currentToken) {
+      return c.text("Unauthorized", 401)
+    }
+
+    const url = new URL(c.req.url)
+    if (!url.searchParams.has("directory")) {
+      url.searchParams.set("directory", targetDirectory)
+    }
+
+    const response = await routes.fetch(new Request(url, c.req.raw), c.env)
+    if (cookie === currentToken) return response
+
+    const headers = new Headers(response.headers)
+    setPlanCookieHeader(headers, currentToken)
+    return new Response(response.body, {
+      status: response.status,
+      statusText: response.statusText,
+      headers,
+    })
+  })
+
+  return app
+}
+
+export const PlanServer = {
+  ensure(input: { directory: string }) {
+    if (server && directory === input.directory) {
+      return {
+        url: server.url.toString(),
+        token,
+      }
+    }
+
+    if (server) {
+      server.stop(true)
+      server = undefined
+    }
+
+    directory = input.directory
+    token = nextToken()
+    const app = appForDirectory(directory, token)
+    server = Bun.serve({
+      hostname: "127.0.0.1",
+      port: 0,
+      idleTimeout: 0,
+      fetch: app.fetch,
+    })
+    setPlanServer({ url: server.url.toString(), token })
+
+    return {
+      url: server.url.toString(),
+      token,
+    }
+  },
+  stop() {
+    setPlanServer(undefined)
+    if (!server) return
+    server.stop(true)
+    server = undefined
+    token = ""
+    directory = ""
+  },
+}

diff --git a/packages/opencode/src/session/plan-user.ts b/packages/opencode/src/session/plan-user.ts
new file mode 100644
index 000000000..d5e2f94b5
--- /dev/null
+++ b/packages/opencode/src/session/plan-user.ts
@@ -0,0 +1,786 @@
+import { createHash } from "node:crypto"
+import path from "node:path"
+import { XMLParser } from "fast-xml-parser"
+
+export type PlanUserSection = {
+  id: string
+  title: string
+}
+
+type PlanUserNodeBase = {
+  id: string
+  commentable: boolean
+}
+
+export type PlanUserHeadingNode = PlanUserNodeBase & {
+  kind: "heading"
+  level: number
+  text: string
+}
+
+export type PlanUserParagraphNode = PlanUserNodeBase & {
+  kind: "paragraph"
+  text: string
+}
+
+export type PlanUserListItem = {
+  id: string
+  text: string
+  commentable: boolean
+}
+
+export type PlanUserListNode = PlanUserNodeBase & {
+  kind: "list"
+  ordered: boolean
+  items: PlanUserListItem[]
+}
+
+export type PlanUserFieldTextRow = {
+  id: string
+  label: "what" | "why"
+  kind: "text"
+  text: string
+  commentable: boolean
+}
+
+export type PlanUserFieldListRow = {
+  id: string
+  label: "files_tests"
+  kind: "list"
+  items: PlanUserListItem[]
+  commentable: boolean
+}
+
+export type PlanUserFieldRow = PlanUserFieldTextRow | PlanUserFieldListRow
+
+export type PlanUserFieldTableNode = PlanUserNodeBase & {
+  kind: "field-table"
+  rows: PlanUserFieldRow[]
+}
+
+export type PlanUserToggleNode = PlanUserNodeBase & {
+  kind: "toggle"
+  title: string
+  children: PlanUserNode[]
+}
+
+export type PlanUserNoteNode = PlanUserNodeBase & {
+  kind: "note"
+  title: string
+  children: PlanUserNode[]
+}
+
+export type PlanUserNode =
+  | PlanUserHeadingNode
+  | PlanUserParagraphNode
+  | PlanUserListNode
+  | PlanUserFieldTableNode
+  | PlanUserToggleNode
+  | PlanUserNoteNode
+
+export type PlanUserDocument = {
+  title: string
+  sourcePath: string
+  generatedAt: string
+  planRevisionID: string
+  sections: PlanUserSection[]
+  nodes: PlanUserNode[]
+}
+
+export type PlanUserTarget = {
+  id: string
+  kind: PlanUserNode["kind"] | "list-item" | "field-row"
+  text: string
+}
+
+const SELF_CONTAINED_PATTERNS = [
+  /\b(previous|prior|earlier)\s+plan\b/i,
+  /\bsee\s+(the\s+)?(previous|prior|earlier)\b/i,
+  /\bsame\s+as\s+before\b/i,
+  /\bunchanged\s+from\b/i,
+  /\bas\s+above\b/i,
+]
+
+export const USER_PLAN_DELIMITER = "=== USER PLAN ==="
+const LEGACY_USER_PLAN_DELIMITER = "===PIANO UTENTE==="
+
+const xmlParser = new XMLParser({
+  ignoreAttributes: false,
+  attributeNamePrefix: "",
+  textNodeName: "#text",
+  trimValues: false,
+  parseTagValue: false,
+})
+
+function escapeHtml(value: string): string {
+  return value
+    .replace(/&/g, "&amp;")
+    .replace(/</g, "&lt;")
+    .replace(/>/g, "&gt;")
+    .replace(/\"/g, "&quot;")
+    .replace(/'/g, "&#39;")
+}
+
+function renderInline(value: string): string {
+  return escapeHtml(value)
+    .replace(/`([^`]+)`/g, "<code>$1</code>")
+    .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
+    .replace(/\[(.*?)\]\((.*?)\)/g, (_match, text, href) => `<a href="${escapeHtml(href)}" target="_blank" rel="noopener noreferrer">${escapeHtml(text)}</a>`)
+}
+
+function slugify(value: string): string {
+  const slug = value
+    .toLowerCase()
+    .replace(/[^a-z0-9]+/g, "-")
+    .replace(/^-+|-+$/g, "")
+  return slug || "section"
+}
+
+function uniqueId(input: string, seen: Map<string, number>) {
+  const base = slugify(input)
+  const count = seen.get(base) ?? 0
+  seen.set(base, count + 1)
+  return count === 0 ? base : `${base}-${count + 1}`
+}
+
+function normalize(markdown: string) {
+  return markdown.trim()
+}
+
+function isolateUserPlanContent(markdown: string) {
+  const normalized = normalize(markdown)
+  for (const delimiter of [USER_PLAN_DELIMITER, LEGACY_USER_PLAN_DELIMITER]) {
+    const markerIndex = normalized.indexOf(delimiter)
+    if (markerIndex >= 0) {
+      return normalized.slice(markerIndex + delimiter.length).trim()
+    }
+  }
+  return normalized
+}
+
+export function sanitizeUserPlanMarkdown(markdown: string) {
+  return isolateUserPlanContent(markdown)
+    .replace(/<system-reminder>[\s\S]*?<\/system-reminder>/gi, "")
+    .split(/\r?\n/)
+    .join("\n")
+    .replace(/\n{3,}/g, "\n\n")
+    .trim()
+}
+
+function escapeXml(value: string): string {
+  return value
+    .replace(/&/g, "&amp;")
+    .replace(/</g, "&lt;")
+    .replace(/>/g, "&gt;")
+    .replace(/"/g, "&quot;")
+    .replace(/'/g, "&apos;")
+}
+
+function asArray<T>(value: T | T[] | undefined): T[] {
+  if (value === undefined) return []
+  return Array.isArray(value) ? value : [value]
+}
+
+function readXmlText(value: unknown): string {
+  if (typeof value === "string") return value.trim()
+  if (Array.isArray(value)) return value.map(readXmlText).filter(Boolean).join(" ").trim()
+  if (value && typeof value === "object") {
+    const record = value as Record<string, unknown>
+    const text = record["#text"]
+    if (typeof text === "string") return text.trim()
+  }
+  return ""
+}
+
+function readXmlParagraphs(value: unknown): string[] {
+  if (!value || typeof value !== "object") {
+    const text = readXmlText(value)
+    return text ? [text] : []
+  }
+
+  const record = value as Record<string, unknown>
+  const paragraphs = asArray(record.p).map(readXmlText).filter(Boolean)
+  if (paragraphs.length) return paragraphs
+  const text = readXmlText(record)
+  return text ? [text] : []
+}
+
+function readXmlItems(value: unknown): string[] {
+  if (!value || typeof value !== "object") return []
+  const record = value as Record<string, unknown>
+  return asArray(record.item).map(readXmlText).filter(Boolean)
+}
+
+function looksLikeXml(value: string) {
+  return /^<\?xml\b|^<user_plan\b/i.test(value.trim())
+}
+
+function hash(markdown: string) {
+  return createHash("sha256").update(normalize(markdown)).digest("hex")
+}
+
+function fallbackTitle(sourcePath: string) {
+  const base = path.basename(sourcePath, path.extname(sourcePath)).replace(/\.user$/, "")
+  return base.replace(/[-_]+/g, " ").trim() || "User plan"
+}
+
+type InternalSection = {
+  level: number
+  title: string
+  body: string
+}
+
+function parseInternalSections(markdown: string) {
+  const lines = markdown.split(/\r?\n/)
+  const sections: InternalSection[] = []
+  let current: InternalSection | undefined
+
+  const pushCurrent = () => {
+    if (!current) return
+    current.body = current.body.trim()
+    sections.push(current)
+    current = undefined
+  }
+
+  for (const line of lines) {
+    const heading = line.match(/^(#{1,6})\s+(.+)$/)
+    if (heading) {
+      pushCurrent()
+      current = {
+        level: heading[1].length,
+        title: heading[2].trim(),
+        body: "",
+      }
+      continue
+    }
+
+    if (current) current.body += `${line}\n`
+  }
+
+  pushCurrent()
+  return sections
+}
+
+function stripMarkdown(value: string) {
+  return value
+    .replace(/`([^`]+)`/g, "$1")
+    .replace(/\*\*([^*]+)\*\*/g, "$1")
+    .replace(/__([^_]+)__/g, "$1")
+    .replace(/\[(.*?)\]\((.*?)\)/g, "$1")
+    .replace(/^#+\s+/gm, "")
+    .trim()
+}
+
+function extractLabeledValue(body: string, label: string) {
+  const match = body.match(new RegExp(`^${label}:\\s*(.+)$`, "im"))
+  return match?.[1]?.trim() ? stripMarkdown(match[1].trim()) : undefined
+}
+
+function internalParagraphs(value: string) {
+  return value
+    .split(/\n\s*\n/g)
+    .map((part) => part.trim())
+    .filter(Boolean)
+    .map((part) => stripMarkdown(part))
+}
+
+function parseFilesTestsItems(value?: string) {
+  if (!value) return []
+  return value
+    .split(/\s*,\s*/)
+    .map((item) => item.trim())
+    .filter(Boolean)
+}
+
+function parseDetailItems(body: string) {
+  return body
+    .split(/\r?\n/)
+    .map((line) => line.trim())
+    .filter((line) => /^[-*]\s+/.test(line) || /^\d+\.\s+/.test(line))
+    .map((line) => line.replace(/^[-*]\s+/, "").replace(/^\d+\.\s+/, "").trim())
+    .map(stripMarkdown)
+    .filter(Boolean)
+}
+
+function buildXmlFieldRow(label: "what" | "why", text: string, seen: Map<string, number>): PlanUserFieldTextRow {
+  return {
+    id: uniqueId(`${label}-${text}`, seen),
+    label,
+    kind: "text",
+    text,
+    commentable: true,
+  }
+}
+
+function buildXmlListItems(prefix: string, items: string[], seen: Map<string, number>) {
+  return items.map((item) => ({
+    id: uniqueId(`${prefix}-${item}`, seen),
+    text: item,
+    commentable: true,
+  }))
+}
+
+function buildXmlDocument(markdown: string, sourcePath: string): PlanUserDocument {
+  const parsed = xmlParser.parse(markdown)
+  const root = parsed?.user_plan
+  if (!root || typeof root !== "object") {
+    throw new Error("User plan XML must contain a <user_plan> root element")
+  }
+
+  const record = root as Record<string, unknown>
+  const seen = new Map<string, number>()
+  const nodes: PlanUserNode[] = []
+
+  const pushParagraphSection = (headingText: string, source: unknown) => {
+    const id = uniqueId(headingText, seen)
+    nodes.push({
+      id,
+      kind: "heading",
+      level: 1,
+      text: headingText,
+      commentable: true,
+    })
+
+    for (const paragraph of readXmlParagraphs(source)) {
+      nodes.push({
+        id: uniqueId(`${headingText}-${paragraph}`, seen),
+        kind: "paragraph",
+        text: paragraph,
+        commentable: true,
+      })
+    }
+  }
+
+  pushParagraphSection("Goal", record.goal)
+  pushParagraphSection("Piano Razionale", record.rationale)
+
+  const steps = record.steps && typeof record.steps === "object" ? asArray((record.steps as Record<string, unknown>).step) : []
+  for (const step of steps) {
+    if (!step || typeof step !== "object") continue
+    const stepRecord = step as Record<string, unknown>
+    const title = readXmlText(stepRecord.title)
+    if (!title) continue
+
+    nodes.push({
+      id: uniqueId(title, seen),
+      kind: "heading",
+      level: 2,
+      text: title,
+      commentable: true,
+    })
+
+    const rows: PlanUserFieldRow[] = []
+    const what = readXmlText(stepRecord.what)
+    const why = readXmlText(stepRecord.why)
+    const filesTests = readXmlItems(stepRecord.files_tests)
+    if (what) rows.push(buildXmlFieldRow("what", what, seen))
+    if (why) rows.push(buildXmlFieldRow("why", why, seen))
+    if (filesTests.length) {
+      rows.push({
+        id: uniqueId(`${title}-files-tests`, seen),
+        label: "files_tests",
+        kind: "list",
+        items: buildXmlListItems(`${title}-files-tests-item`, filesTests, seen),
+        commentable: true,
+      })
+    }
+    if (rows.length) {
+      nodes.push({
+        id: uniqueId(`${title}-fields`, seen),
+        kind: "field-table",
+        rows,
+        commentable: false,
+      })
+    }
+
+    const detailItems = readXmlItems(stepRecord.details)
+    if (detailItems.length) {
+      nodes.push({
+        id: uniqueId(`${title}-details`, seen),
+        kind: "list",
+        ordered: false,
+        items: buildXmlListItems(`${title}-detail`, detailItems, seen),
+        commentable: true,
+      })
+    }
+  }
+
+  const sections = gatherSections(nodes)
+  const title = readXmlText(record.title) || resolveTitle(nodes, sourcePath)
+  const sectionTitles = new Set(sections.map((section) => section.title.toLowerCase()))
+  if (!sectionTitles.has("goal") || !sectionTitles.has("piano razionale")) {
+    throw new Error("User plan XML must include <goal> and <rationale> sections")
+  }
+
+  return {
+    title,
+    sourcePath,
+    generatedAt: new Date().toLocaleString(),
+    planRevisionID: hash(markdown),
+    sections,
+    nodes,
+  }
+}
+
+function renderXmlSection(tag: string, paragraphs: string[]) {
+  const body = paragraphs.map((paragraph) => `    <p>${escapeXml(paragraph)}</p>`).join("\n")
+  return [`  <${tag}>`, body || "    <p></p>", `  </${tag}>`].join("\n")
+}
+
+function renderXmlList(tag: string, items: string[]) {
+  if (!items.length) return ""
+  return [
+    `      <${tag}>`,
+    ...items.map((item) => `        <item>${escapeXml(item)}</item>`),
+    `      </${tag}>`,
+  ].join("\n")
+}
+
+function deriveXmlUserPlan(markdown: string) {
+  const sections = parseInternalSections(sanitizeUserPlanMarkdown(markdown))
+  const goalSection = sections.find((section) => section.title.toLowerCase() === "goal")
+  const rationaleSection = sections.find((section) => ["plan rationale", "piano razionale"].includes(section.title.toLowerCase()))
+  const stepSections = sections.filter((section) => section.level === 2 && /^(step|phase)\b/i.test(section.title))
+
+  const goalParagraphs = internalParagraphs(goalSection?.body ?? "Review the current plan.")
+  const rationaleParagraphs = internalParagraphs(rationaleSection?.body ?? "This review plan mirrors the current internal plan so it can be reviewed clearly.")
+  const title = goalParagraphs[0] || "User plan"
+
+  const steps = stepSections.length
+    ? stepSections
+    : [
+        {
+          level: 2,
+          title: "Review the current work",
+          body: sections.map((section) => `${section.title}\n\n${section.body}`.trim()).join("\n\n"),
+        },
+      ]
+
+  return [
+    USER_PLAN_DELIMITER,
+    "",
+    `<user_plan>`,
+    `  <title>${escapeXml(title)}</title>`,
+    renderXmlSection("goal", goalParagraphs.length ? goalParagraphs : ["Review the current plan."]),
+    renderXmlSection("rationale", rationaleParagraphs.length ? rationaleParagraphs : ["Explain the reasoning behind the implementation plan."]),
+    `  <steps>`,
+    ...steps.flatMap((section) => {
+      const what = extractLabeledValue(section.body, "What") ?? internalParagraphs(section.body)[0] ?? section.title
+      const why = extractLabeledValue(section.body, "Why") ?? internalParagraphs(section.body)[1] ?? "Explain why this step matters."
+      const filesTests = parseFilesTestsItems(extractLabeledValue(section.body, "Files/Tests"))
+      const details = parseDetailItems(section.body)
+      return [
+        `    <step>`,
+        `      <title>${escapeXml(section.title)}</title>`,
+        `      <what>${escapeXml(what)}</what>`,
+        `      <why>${escapeXml(why)}</why>`,
+        ...(filesTests.length ? [renderXmlList("files_tests", filesTests)] : []),
+        ...(details.length ? [renderXmlList("details", details)] : []),
+        `    </step>`,
+      ]
+    }),
+    `  </steps>`,
+    `</user_plan>`,
+  ]
+    .filter(Boolean)
+    .join("\n")
+}
+
+function parseList(lines: string[], index: number, seen: Map<string, number>) {
+  const items: PlanUserListItem[] = []
+  let cursor = index
+  let ordered = false
+  while (cursor < lines.length) {
+    const line = lines[cursor].trim()
+    const unordered = line.match(/^[-*]\s+(.+)$/)
+    const numbered = line.match(/^\d+\.\s+(.+)$/)
+    if (!unordered && !numbered) break
+    const text = (unordered?.[1] ?? numbered?.[1] ?? "").trim()
+    ordered ||= Boolean(numbered)
+    items.push({
+      id: uniqueId(`item-${text}`, seen),
+      text,
+      commentable: true,
+    })
+    cursor += 1
+  }
+  return {
+    node: {
+      id: uniqueId(items.map((item) => item.text).join(" "), seen),
+      kind: "list" as const,
+      ordered,
+      items,
+      commentable: true,
+    },
+    nextIndex: cursor,
+  }
+}
+
+function parseParagraph(lines: string[], index: number, seen: Map<string, number>) {
+  const chunk: string[] = []
+  let cursor = index
+  while (cursor < lines.length) {
+    const line = lines[cursor]
+    const trimmed = line.trim()
+    if (!trimmed) break
+    if (/^#{1,6}\s+/.test(trimmed)) break
+    if (/^:::(toggle|note)\[/.test(trimmed)) break
+    if (/^:::$/.test(trimmed)) break
+    if (/^[-*]\s+/.test(trimmed) || /^\d+\.\s+/.test(trimmed)) break
+    chunk.push(trimmed)
+    cursor += 1
+  }
+  return {
+    node: {
+      id: uniqueId(chunk.join(" "), seen),
+      kind: "paragraph" as const,
+      text: chunk.join(" "),
+      commentable: true,
+    },
+    nextIndex: cursor,
+  }
+}
+
+function parseBlock(kind: "toggle" | "note", title: string, lines: string[], index: number, seen: Map<string, number>) {
+  let depth = 1
+  let cursor = index + 1
+  const body: string[] = []
+  while (cursor < lines.length) {
+    const trimmed = lines[cursor].trim()
+    if (/^:::(toggle|note)\[/.test(trimmed)) depth += 1
+    if (trimmed === ":::") {
+      depth -= 1
+      if (depth === 0) break
+    }
+    body.push(lines[cursor])
+    cursor += 1
+  }
+  const children = parseNodes(body.join("\n"), seen)
+  return {
+    node: {
+      id: uniqueId(`${kind}-${title}`, seen),
+      kind,
+      title,
+      children,
+      commentable: true,
+    } satisfies PlanUserToggleNode | PlanUserNoteNode,
+    nextIndex: Math.min(cursor + 1, lines.length),
+  }
+}
+
+function parseNodes(markdown: string, seen = new Map<string, number>()) {
+  const lines = normalize(markdown).split(/\r?\n/)
+  const nodes: PlanUserNode[] = []
+  let index = 0
+  while (index < lines.length) {
+    const raw = lines[index]
+    const line = raw.trim()
+    if (!line) {
+      index += 1
+      continue
+    }
+
+    const heading = line.match(/^(#{1,6})\s+(.+)$/)
+    if (heading) {
+      nodes.push({
+        id: uniqueId(heading[2], seen),
+        kind: "heading",
+        level: heading[1].length,
+        text: heading[2].trim(),
+        commentable: true,
+      })
+      index += 1
+      continue
+    }
+
+    const toggle = line.match(/^:::toggle\[(.+)\]$/)
+    if (toggle) {
+      const parsed = parseBlock("toggle", toggle[1].trim(), lines, index, seen)
+      nodes.push(parsed.node)
+      index = parsed.nextIndex
+      continue
+    }
+
+    const note = line.match(/^:::note\[(.+)\]$/)
+    if (note) {
+      const parsed = parseBlock("note", note[1].trim(), lines, index, seen)
+      nodes.push(parsed.node)
+      index = parsed.nextIndex
+      continue
+    }
+
+    if (/^[-*]\s+/.test(line) || /^\d+\.\s+/.test(line)) {
+      const parsed = parseList(lines, index, seen)
+      nodes.push(parsed.node)
+      index = parsed.nextIndex
+      continue
+    }
+
+    const parsed = parseParagraph(lines, index, seen)
+    nodes.push(parsed.node)
+    index = parsed.nextIndex
+  }
+  return nodes
+}
+
+function gatherSections(nodes: PlanUserNode[]) {
+  return nodes
+    .filter((node): node is PlanUserHeadingNode => node.kind === "heading")
+    .filter((node) => node.level <= 2)
+    .map((node) => ({ id: node.id, title: node.text }))
+}
+
+function resolveTitle(nodes: PlanUserNode[], sourcePath: string) {
+  const goalIndex = nodes.findIndex((node) => node.kind === "heading" && node.text.toLowerCase() === "goal")
+  if (goalIndex >= 0) {
+    const next = nodes.slice(goalIndex + 1).find((node) => node.kind === "paragraph")
+    if (next?.kind === "paragraph" && next.text.trim()) return next.text.trim()
+  }
+  return fallbackTitle(sourcePath)
+}
+
+export function assertSelfContainedPlan(markdown: string) {
+  const normalized = normalize(markdown)
+  for (const pattern of SELF_CONTAINED_PATTERNS) {
+    if (pattern.test(normalized)) {
+      throw new Error("User plan must be self-contained and must not refer to a previous plan")
+    }
+  }
+}
+
+export function deriveUserPlanMarkdown(markdown: string) {
+  return deriveXmlUserPlan(markdown)
+}
+
+export function buildPlanUserDocument(markdown: string, sourcePath: string): PlanUserDocument {
+  const sanitized = sanitizeUserPlanMarkdown(markdown)
+  assertSelfContainedPlan(sanitized)
+  if (looksLikeXml(sanitized)) return buildXmlDocument(sanitized, sourcePath)
+  const nodes = parseNodes(sanitized)
+  const sections = gatherSections(nodes)
+  const sectionTitles = new Set(sections.map((section) => section.title.toLowerCase()))
+  if (!sectionTitles.has("goal") || !sectionTitles.has("piano razionale")) {
+    throw new Error("User plan must include # Goal and # Piano Razionale sections")
+  }
+
+  return {
+    title: resolveTitle(nodes, sourcePath),
+    sourcePath,
+    generatedAt: new Date().toLocaleString(),
+    planRevisionID: hash(sanitized),
+    sections,
+    nodes,
+  }
+}
+
+function renderNode(node: PlanUserNode): string {
+  switch (node.kind) {
+    case "heading": {
+      const level = Math.min(Math.max(node.level, 1), 4)
+      return `<h${level} data-plan-node-id="${node.id}">${renderInline(node.text)}</h${level}>`
+    }
+    case "paragraph":
+      return `<p data-plan-node-id="${node.id}">${renderInline(node.text)}</p>`
+    case "list": {
+      const tag = node.ordered ? "ol" : "ul"
+      return `<${tag} data-plan-node-id="${node.id}">${node.items.map((item) => `<li data-plan-node-id="${item.id}">${renderInline(item.text)}</li>`).join("")}</${tag}>`
+    }
+    case "field-table":
+      return [
+        '<table class="plan-user-field-table">',
+        '<tbody>',
+        ...node.rows.map((row) => {
+          const label = row.label === "files_tests" ? "Files / Tests" : row.label[0].toUpperCase() + row.label.slice(1)
+          const value =
+            row.kind === "list"
+              ? `<ul>${row.items.map((item) => `<li data-plan-node-id="${item.id}">${renderInline(item.text)}</li>`).join("")}</ul>`
+              : `<span data-plan-node-id="${row.id}">${renderInline(row.text)}</span>`
+          return `<tr><th>${label}</th><td>${value}</td></tr>`
+        }),
+        '</tbody>',
+        '</table>',
+      ].join("")
+    case "toggle":
+      return `<details data-plan-node-id="${node.id}"><summary>${renderInline(node.title)}</summary>${node.children.map(renderNode).join("")}</details>`
+    case "note":
+      return `<section data-plan-node-id="${node.id}" class="plan-user-note"><h3>${renderInline(node.title)}</h3>${node.children.map(renderNode).join("")}</section>`
+  }
+}
+
+export function renderPlanUserHtml(document: PlanUserDocument) {
+  return [
+    "<!doctype html>",
+    '<html lang="en">',
+    "<head>",
+    '  <meta charset="utf-8">',
+    '  <meta name="viewport" content="width=device-width, initial-scale=1">',
+    `  <title>${escapeHtml(document.title)}</title>`,
+    "  <style>",
+    "    :root { color-scheme: light dark; --bg: #f5f5f4; --panel: #ffffff; --text: #1c1917; --muted: #57534e; --border: #d6d3d1; --accent: #0f766e; --note: #f0fdfa; }",
+    "    @media (prefers-color-scheme: dark) { :root { --bg: #111111; --panel: #171717; --text: #f5f5f5; --muted: #a3a3a3; --border: #333333; --accent: #5eead4; --note: #132524; } }",
+    "    body { margin: 0; background: var(--bg); color: var(--text); font-family: Inter, system-ui, sans-serif; }",
+    "    main { max-width: 960px; margin: 0 auto; padding: 32px 16px 72px; }",
+    "    article { background: var(--panel); border: 1px solid var(--border); border-radius: 12px; padding: 24px; }",
+    "    details { margin: 16px 0; padding: 12px 14px; border: 1px solid var(--border); border-radius: 10px; }",
+    "    summary { cursor: pointer; text-decoration: underline; text-underline-offset: 0.2em; }",
+    "    code { background: rgba(127,127,127,0.12); padding: 0.15rem 0.35rem; border-radius: 6px; }",
+    "    .plan-user-field-table { width: 100%; border-collapse: collapse; margin: 18px 0; border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }",
+    "    .plan-user-field-table th, .plan-user-field-table td { text-align: left; padding: 12px 14px; border-bottom: 1px solid var(--border); vertical-align: top; }",
+    "    .plan-user-field-table th { width: 180px; text-transform: uppercase; letter-spacing: 0.06em; font-size: 0.78rem; color: var(--muted); background: rgba(127,127,127,0.08); }",
+    "    .plan-user-field-table tr:last-child th, .plan-user-field-table tr:last-child td { border-bottom: none; }",
+    "    .plan-user-note { margin: 16px 0; padding: 14px; border: 1px solid var(--border); border-radius: 10px; background: var(--note); }",
+    "  </style>",
+    "</head>",
+    "<body>",
+    "  <main>",
+    "    <article>",
+    document.nodes.map(renderNode).join("\n"),
+    "    </article>",
+    "  </main>",
+    "</body>",
+    "</html>",
+  ].join("\n")
+}
+
+function walkTargets(nodes: PlanUserNode[], out: PlanUserTarget[]) {
+  for (const node of nodes) {
+    switch (node.kind) {
+      case "heading":
+      case "paragraph":
+        out.push({ id: node.id, kind: node.kind, text: node.text })
+        break
+      case "toggle":
+        out.push({ id: node.id, kind: node.kind, text: node.title })
+        walkTargets(node.children, out)
+        break
+      case "note":
+        out.push({ id: node.id, kind: node.kind, text: node.title })
+        walkTargets(node.children, out)
+        break
+      case "field-table":
+        for (const row of node.rows) {
+          if (row.kind === "list") {
+            out.push({ id: row.id, kind: "field-row", text: row.items.map((item) => item.text).join("\n") })
+            for (const item of row.items) out.push({ id: item.id, kind: "list-item", text: item.text })
+          } else {
+            out.push({ id: row.id, kind: "field-row", text: row.text })
+          }
+        }
+        break
+      case "list":
+        out.push({ id: node.id, kind: node.kind, text: node.items.map((item) => item.text).join("\n") })
+        for (const item of node.items) out.push({ id: item.id, kind: "list-item", text: item.text })
+        break
+    }
+  }
+}
+
+export function flattenPlanUserTargets(document: PlanUserDocument) {
+  const out: PlanUserTarget[] = []
+  walkTargets(document.nodes, out)
+  return out
+}
+
+export function findPlanUserTarget(document: PlanUserDocument, nodeID: string) {
+  return flattenPlanUserTargets(document).find((target) => target.id === nodeID)
+}

